# Base de datos PostgreSQL
# URL de conexión a la base de datos. Debe apuntar al pooler (host contiene "-pooler").
#
# PRODUCCIÓN (Vercel): usar branch "production" de Neon
# DESARROLLO LOCAL (.env.local): usar branch "development" de Neon
# Obtener las URLs en Neon: Project → Branch → Connection string
#
DATABASE_URL=
# Direct URL (sin pooler) usado por Prisma para migraciones.
DIRECT_URL=

# Mercado Pago
# Token de acceso de Mercado Pago para procesar pagos
# Obtener desde: https://www.mercadopago.com.ar/developers/panel/credentials
MP_ACCESS_TOKEN=
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_REDIRECT_URI=
# MP_ENV puede ser "test" o "prod" (solo para logs/flags)
MP_ENV=

# URL canónica de la app (fuente de verdad para enlaces server-side y callbacks)
# Convención por entorno:
# - local:      http://localhost:3002
# - staging:    https://fotoffice.staging.dnxsuite.com
# - producción: https://fotoffice.dnxsuite.com
APP_URL=

# Auth
# Secreto para cookies/sesiones (usar uno fuerte en prod)
AUTH_SECRET=

# URL pública usada por metadata y cliente (debe coincidir con APP_URL por entorno)
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_BASE_URL=
AUTH_URL=
# Legacy opcional (compatibilidad): mantener igual a APP_URL si existe en tu entorno
NEXTAUTH_URL=

# Resend (Email)
# API Key de Resend para enviar emails
# Obtener desde: https://resend.com/api-keys
RESEND_API_KEY=

# Email del remitente (debe estar verificado en Resend)
# Ejemplo: noreply@tudominio.com o contacto@tudominio.com
EMAIL_FROM=

# Respuestas (reply-to) para soporte/admin
EMAIL_REPLY_TO=

# Admin seed (opcional)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URI de callback registrada en Google Console para esta app.
# Si se deja vacío, usa: ${APP_URL}/api/auth/google/callback
GOOGLE_REDIRECT_URI=

# Cookie compartida entre subdominios (SSO)
# - local: dejar vacío (host-only)
# - staging: .staging.dnxsuite.com
# - producción: .dnxsuite.com
COOKIE_DOMAIN=

# Cron jobs (protección de endpoints)
CRON_SECRET=

# AWS Rekognition
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
REKOGNITION_COLLECTION_ID=

# Google Vision (JSON completo como string)
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Upload limits
# Tamaño máximo por archivo en API (bytes)
MAX_FILE_SIZE=
# Límite en frontend (MB)
NEXT_PUBLIC_MAX_UPLOAD_MB=

# Watermark compradas (opcional)
WATERMARK_BOUGHT_ENABLED=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_BUCKET=
R2_PUBLIC_URL=
R2_PUBLIC_BASE_URL=
NEXT_PUBLIC_R2_PUBLIC_URL=
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=

# ICC profile impresión (opcional)
PRINT_ICC_PROFILE_PATH=
PRINT_ICC_PROFILE_BASE64=

# Testing: Redirige todos los emails a este email (útil en modo de prueba de Resend)
# Solo para desarrollo. Dejar vacío en producción.
# TEST_EMAIL_OVERRIDE=dnxfotografia@gmail.com

# WhatsApp (Meta Cloud API) - recordatorios + entrega post-compra
# Obtener desde: https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=1077714545419812
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v19.0

# URL base para links (recordatorios, entrega post-compra)
APP_BASE_URL=https://www.compramelafoto.com
