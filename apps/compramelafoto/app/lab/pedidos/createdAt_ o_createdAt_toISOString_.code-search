lib/prisma.ts:
  1: import { PrismaClient } from "@prisma/client";
  2: 
  3: const globalForPrisma = globalThis as unknown as { prisma?: PrismaClient };
  4: 
  5: export const prisma = globalForPrisma.prisma ?? new PrismaClient();
  6: 
  7: if (process.env.NODE_ENV !== "production") globalForPrisma.prisma = prisma;
  8: 

prisma/schema.prisma:
    1: generator client {
    2:   provider = "prisma-client-js"
    3: }
    4: 
    5: datasource db {
    6:   provider = "postgresql"
    7:   url      = env("DATABASE_URL")
    8: }
    9: 
   10: enum Role {
   11:   OWNER
   12:   PHOTOGRAPHER
   13: }
   14: 
   15: enum OrderStatus {
   16:   PENDING
   17:   PAID
   18:   CANCELED
   19:   REFUNDED
   20: }
   21: 
   22: /**
   23:  * Para el módulo de impresión:
   24:  * "Acabado" (finish) es más claro que "tipo de papel".
   25:  */
   26: enum PrintFinish {
   27:   BRILLO
   28:   MATE
   29: }
   30: 
   31: /**
   32:  * Estados del pedido de impresión (operativo de laboratorio)
   33:  */
   34: enum PrintOrderStatus {
   35:   CREATED
   36:   PAID
   37:   IN_PRODUCTION
   38:   READY
   39:   DELIVERED
   40:   CANCELED
   41: }
   42: 
   43: model User {
   44:   id        Int      @id @default(autoincrement())
   45:   email     String   @unique
   46:   password  String?
   47:   role      Role     @default(PHOTOGRAPHER)
   48:   name      String?
   49:   createdAt DateTime @default(now())
   50: 
   51:   albums    Album[]
   52: }
   53: 
   54: model Album {
   55:   id         Int      @id @default(autoincrement())
   56:   userId     Int
   57:   title      String
   58:   location   String?
   59:   eventDate  DateTime?
   60:   publicSlug String   @unique
   61:   createdAt  DateTime @default(now())
   62: 
   63:   user       User     @relation(fields: [userId], references: [id])
   64:   photos     Photo[]
   65:   orders     Order[]
   66: 
   67:   @@index([userId])
   68: }
   69: 
   70: model Photo {
   71:   id          Int      @id @default(autoincrement())
   72:   albumId     Int
   73:   // URL de previsualización (baja calidad / watermark)
   74:   previewUrl  String
   75:   // Key/identificador del original (alta calidad) en el bucket privado
   76:   originalKey String
   77:   createdAt   DateTime @default(now())
   78: 
   79:   album       Album      @relation(fields: [albumId], references: [id])
   80:   items       OrderItem[]
   81: 
   82:   @@index([albumId])
   83: }
   84: 
   85: model Order {
   86:   id         Int         @id @default(autoincrement())
   87:   albumId    Int
   88:   buyerEmail String
   89:   status     OrderStatus @default(PENDING)
   90:   // total en centavos (ej: ARS o USD según definas después)
   91:   totalCents Int         @default(0)
   92:   createdAt  DateTime    @default(now())
   93: 
   94:   album      Album      @relation(fields: [albumId], references: [id])
   95:   items      OrderItem[]
   96: 
   97:   @@index([albumId])
   98: }
   99: 
  100: model OrderItem {
  101:   id         Int   @id @default(autoincrement())
  102:   orderId    Int
  103:   photoId    Int
  104:   priceCents Int   @default(0)
  105: 
  106:   order      Order @relation(fields: [orderId], references: [id])
  107:   photo      Photo @relation(fields: [photoId], references: [id])
  108: 
  109:   @@index([orderId])
  110:   @@index([photoId])
  111:   @@unique([orderId, photoId])
  112: }
  113: 
  114: /**
  115:  * Pedido de impresión (cliente sube sus fotos)
  116:  */
  117: model PrintOrder {
  118:   id        Int             @id @default(autoincrement())
  119:   createdAt DateTime        @default(now())
  120:   updatedAt DateTime        @updatedAt
  121: 
  122:   // Datos del cliente (simple para MVP)
  123:   customerName  String?
  124:   customerEmail String?
  125:   customerPhone String?
  126: 
  127:   // Estado del pedido
  128:   status   PrintOrderStatus @default(CREATED)
  129: 
  130:   // Totales (en pesos o centavos: por ahora lo mantenemos como Int)
  131:   currency String           @default("ARS")
  132:   total    Int              @default(0)
  133: 
  134:   // Relación con items
  135:   items PrintOrderItem[]
  136: }
  137: 
  138: /**
  139:  * Item de impresión: UNA foto subida + configuración (tamaño, acabado, cantidad)
  140:  */
  141: model PrintOrderItem {
  142:   id           Int         @id @default(autoincrement())
  143:   createdAt    DateTime    @default(now())
  144: 
  145:   // Relación
  146:   order        PrintOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  147:   orderId      Int
  148: 
  149:   // Archivo subido (key interna)
  150:   fileKey      String
  151: 
  152:   // Nombre original (sirve para export/PDF y trazabilidad)
  153:   originalName String?
  154: 
  155:   // Producto
  156:   size         String
  157:   finish       PrintFinish @default(BRILLO) // 👈 ACABADO: BRILLO default
  158: 
  159:   quantity     Int         @default(1)
  160: 
  161:   // Precios
  162:   unitPrice    Int         @default(0)
  163:   subtotal     Int         @default(0)
  164: 
  165:   @@index([orderId])
  166: }
  167: 

scripts/seed.ts:
   1: import { PrismaClient } from "@prisma/client";
   2: 
   3: const prisma = new PrismaClient();
   4: 
   5: async function main() {
   6:   const user = await prisma.user.upsert({
   7:     where: { email: "daniel@demo.com" },
   8:     update: { name: "Daniel", role: "OWNER" },
   9:     create: { email: "daniel@demo.com", name: "Daniel", role: "OWNER" },
  10:   });
  11: 
  12:   const album = await prisma.album.upsert({
  13:     where: { publicSlug: "caminito-prueba" },
  14:     update: { title: "Caminito - Prueba", userId: user.id },
  15:     create: {
  16:       title: "Caminito - Prueba",
  17:       publicSlug: "caminito-prueba",
  18:       userId: user.id,
  19:     },
  20:   });
  21: 
  22:   console.log("✅ Seed completado");
  23:   console.log({ userId: user.id, albumId: album.id, slug: album.publicSlug });
  24: }
  25: 
  26: main()
  27:   .catch((e) => {
  28:     console.error("❌ Error en seed", e);
  29:     process.exit(1);
  30:   })
  31:   .finally(async () => {
  32:     await prisma.$disconnect();
  33:   });
  34: 
