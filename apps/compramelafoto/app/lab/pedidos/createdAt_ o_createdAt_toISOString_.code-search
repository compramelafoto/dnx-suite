app/api/print-orders/[id]/export/route.ts:
    1: import { NextResponse } from "next/server";
    2: import { prisma } from "@/lib/prisma";
    3: import path from "path";
    4: import fs from "fs/promises";
    5: import archiver from "archiver";
    6: import { Readable } from "stream";
    7: import { PDFDocument, StandardFonts } from "pdf-lib";
    8: 
    9: export const runtime = "nodejs";
   10: export const dynamic = "force-dynamic";
   11: 
   12: function safeName(name: string) {
   13:   return (name || "")
   14:     .replace(/[\/\\?%*:|"<>]/g, "-")
   15:     .replace(/\s+/g, " ")
   16:     .trim();
   17: }
   18: 
   19: function pad(n: number, len = 6) {
   20:   return String(n).padStart(len, "0");
   21: }
   22: 
   23: function formatDate(d: Date) {
   24:   const dd = String(d.getDate()).padStart(2, "0");
   25:   const mm = String(d.getMonth() + 1).padStart(2, "0");
   26:   const yyyy = d.getFullYear();
   27:   const hh = String(d.getHours()).padStart(2, "0");
   28:   const min = String(d.getMinutes()).padStart(2, "0");
   29:   return `${dd}/${mm}/${yyyy} ${hh}:${min}`;
   30: }
   31: 
   32: function parseId(raw: any): number | null {
   33:   const val = Array.isArray(raw) ? raw[0] : raw;
   34:   const n = Number(val);
   35:   return Number.isFinite(n) ? n : null;
   36: }
   37: 
   38: function summarize(order: any) {
   39:   const summary: Record<string, Record<string, { photos: number; copies: number }>> = {};
   40:   for (const it of order.items) {
   41:     const finish = String(it.finish);
   42:     const size = String(it.size);
   43:     summary[finish] ??= {};
   44:     summary[finish][size] ??= { photos: 0, copies: 0 };
   45:     summary[finish][size].photos += 1;
   46:     summary[finish][size].copies += Number(it.quantity || 0);
   47:   }
   48:   return summary;
   49: }
   50: 
   51: async function buildPdf(order: any): Promise<Uint8Array> {
   52:   const pdfDoc = await PDFDocument.create();
   53:   const font = await pdfDoc.embedFont(StandardFonts.Helvetica);
   54: 
   55:   const page = pdfDoc.addPage([595.28, 841.89]); // A4
   56:   const { width, height } = page.getSize();
   57: 
   58:   let y = height - 50;
   59:   const left = 50;
   60: 
   61:   const draw = (text: string, size = 11, gap = 16) => {
   62:     page.drawText(text, { x: left, y, size, font });
   63:     y -= gap;
   64:   };
   65: 
   66:   // Título
   67:   page.drawText("RESUMEN DE PEDIDO - IMPRESIONES", { x: left, y, size: 16, font });
   68:   y -= 28;
   69: 
   70:   draw(`Pedido N°: ${order.id}`, 12);
   71:   draw(`Fecha: ${formatDate(order.createdAt)}`, 12);
   72:   draw(`Moneda: ${order.currency}`, 12);
   73:   draw(`Total: ${order.total}`, 12);
   74:   y -= 10;
   75: 
   76:   draw("Datos del cliente", 13);
   77:   draw(`Nombre: ${order.customerName || "-"}`);
   78:   draw(`Email: ${order.customerEmail || "-"}`);
   79:   draw(`Teléfono: ${order.customerPhone || "-"}`);
   80:   y -= 10;
   81: 
   82:   draw("Resumen de producción (por acabado y tamaño)", 13);
   83:   const summary = summarize(order);
   84: 
   85:   const finishes = Object.keys(summary).sort();
   86:   for (const finish of finishes) {
   87:     draw(`Acabado: ${finish}`, 12);
   88:     const sizes = Object.keys(summary[finish]).sort();
   89:     for (const size of sizes) {
   90:       const row = summary[finish][size];
   91:       draw(`• ${size} — Fotos: ${row.photos} — Copias: ${row.copies}`, 11);
   92:     }
   93:     y -= 6;
   94:     if (y < 80) break; // por ahora, simple (1 página)
   95:   }
   96: 
   97:   y -= 10;
   98:   draw(
   99:     "Notas: Archivos organizados por Acabado y luego por Tamaño. Cada archivo indica cantidad (xNN) y tamaño.",
  100:     10,
  101:     14
  102:   );
  103: 
  104:   return await pdfDoc.save();
  105: }
  106: 
  107: export async function GET(
  108:   _req: Request,
  109:   ctx: { params: { id: string } } | { params: Promise<{ id: string }> }
  110: ) {
  111:   try {
  112:     const params: any = await Promise.resolve((ctx as any).params);
  113:     const orderId = parseId(params?.id);
  114: 
  115:     if (!orderId) {
  116:       return NextResponse.json(
  117:         { error: "ID inválido", debug: { raw: params?.id } },
  118:         { status: 400 }
  119:       );
  120:     }
  121: 
  122:     const order = await prisma.printOrder.findUnique({
  123:       where: { id: orderId },
  124:       include: { items: true },
  125:     });
  126: 
  127:     if (!order) {
  128:       return NextResponse.json({ error: "Pedido no encontrado" }, { status: 404 });
  129:     }
  130: 
  131:     const customer = safeName(order.customerName || "Cliente");
  132:     const baseFolder = `Pedido-${pad(order.id)} - ${customer}`;
  133: 
  134:     // Manifest técnico
  135:     const lines: string[] = [];
  136:     lines.push(`Pedido: ${order.id}`);
  137:     lines.push(`Cliente: ${order.customerName || "-"}`);
  138:     lines.push(`Email: ${order.customerEmail || "-"}`);
  139:     lines.push(`Teléfono: ${order.customerPhone || "-"}`);
  140:     lines.push(`Fecha: ${order.createdAt.toISOString()}`);
  141:     lines.push(`Moneda: ${order.currency}`);
  142:     lines.push(`Total: ${order.total}`);
  143:     lines.push("");
  144:     lines.push("ITEMS:");
  145:     lines.push("Acabado | Tamaño | Cantidad | Archivo original | fileKey | Ruta ZIP");
  146: 
  147:     // ZIP streaming
  148:     const archive = archiver("zip", { zlib: { level: 9 } });
  149:     archive.on("warning", (err) => console.warn("ARCHIVER WARNING:", err));
  150:     archive.on("error", (err) => {
  151:       throw err;
  152:     });
  153: 
  154:     for (const it of order.items) {
  155:       const finish = safeName(String(it.finish));
  156:       const size = safeName(String(it.size));
  157:       const qty = Number(it.quantity || 0);
  158: 
  159:       const originalName = safeName(it.originalName || it.fileKey);
  160:       const ext = path.extname(originalName) || path.extname(it.fileKey) || ".jpg";
  161: 
  162:       // ✅ Nombre corto: cantidad + tamaño + original (acabado está en carpeta)
  163:       const filename = `x${String(qty).padStart(2, "0")} - ${size} - ${originalName.replace(ext, "")}${ext}`;
  164:       const zipPath = `${baseFolder}/${finish}/${size}/${filename}`;
  165: 
  166:       const diskPath = path.join(process.cwd(), "public", "uploads", it.fileKey);
  167: 
  168:       try {
  169:         await fs.access(diskPath);
  170:         archive.file(diskPath, { name: zipPath });
  171:         lines.push(`${finish} | ${size} | ${qty} | ${it.originalName || "-"} | ${it.fileKey} | ${zipPath}`);
  172:       } catch {
  173:         lines.push(`${finish} | ${size} | ${qty} | ${it.originalName || "-"} | ${it.fileKey} | (FALTA ARCHIVO)`);
  174:       }
  175:     }
  176: 
  177:     // MANIFEST.txt
  178:     archive.append(lines.join("\n"), { name: `${baseFolder}/MANIFEST.txt` });
  179: 
  180:     // PDF (sin pdfkit)
  181:     const pdfBytes = await buildPdf(order);
  182:     archive.append(Buffer.from(pdfBytes), { name: `${baseFolder}/RESUMEN_PEDIDO.pdf` });
  183: 
  184:     // Response ZIP
  185:     const webStream = Readable.toWeb(archive);
  186:     const headers = new Headers();
  187:     headers.set("Content-Type", "application/zip");
  188:     headers.set("Content-Disposition", `attachment; filename="${safeName(baseFolder)}.zip"`);
  189: 
  190:     archive.finalize();
  191:     return new Response(webStream as any, { headers });
  192:   } catch (err: any) {
  193:     console.error("EXPORT ERROR >>>", err);
  194:     return NextResponse.json(
  195:       { error: "Error exportando pedido", detail: String(err?.message ?? err) },
  196:       { status: 500 }
  197:     );
  198:   }
  199: }
  200: 

app/api/print-orders/bulk-status/route.ts:
   1: import { NextResponse } from "next/server";
   2: import { prisma } from "@/lib/prisma";
   3: 
   4: export const runtime = "nodejs";
   5: export const dynamic = "force-dynamic";
   6: 
   7: const ALLOWED = new Set(["CREATED", "IN_PRODUCTION", "READY", "DELIVERED", "CANCELED"]);
   8: 
   9: export async function PATCH(req: Request) {
  10:   try {
  11:     const body = await req.json().catch(() => ({}));
  12:     const ids = Array.isArray(body?.ids) ? body.ids.map((n: any) => Number(n)).filter(Number.isFinite) : [];
  13:     const status = String(body?.status || "").toUpperCase();
  14: 
  15:     if (ids.length === 0) {
  16:       return NextResponse.json({ error: "ids vacío" }, { status: 400 });
  17:     }
  18:     if (!ALLOWED.has(status)) {
  19:       return NextResponse.json({ error: "Estado inválido", allowed: Array.from(ALLOWED) }, { status: 400 });
  20:     }
  21: 
  22:     const result = await prisma.printOrder.updateMany({
  23:       where: { id: { in: ids } },
  24:       data: { status },
  25:     });
  26: 
  27:     return NextResponse.json({ ok: true, updated: result.count }, { status: 200 });
  28:   } catch (err: any) {
  29:     console.error("BULK STATUS ERROR >>>", err);
  30:     return NextResponse.json(
  31:       { error: "Error actualizando masivo", detail: String(err?.message ?? err) },
  32:       { status: 500 }
  33:     );
  34:   }
  35: }
  36: 

app/api/uploads/route.ts:
   1: 
   2: import { NextResponse } from "next/server";
   3: import path from "path";
   4: import crypto from "crypto";
   5: 
   6: // Fuerza runtime Node (fs) y evita caches raros en dev
   7: export const runtime = "nodejs";
   8: export const dynamic = "force-dynamic";
   9: 
  10: export async function POST(req: Request) {
  11:   try {
  12:     // Importar fs/promises DENTRO del handler evita crashes en build/dev
  13:     const fs = await import("fs/promises");
  14: 
  15:     const formData = await req.formData();
  16:     const files = formData.getAll("files");
  17: 
  18:     if (!files || files.length === 0) {
  19:       return NextResponse.json({ error: "No files uploaded" }, { status: 400 });
  20:     }
  21: 
  22:     const uploadsDir = path.join(process.cwd(), "public", "uploads");
  23:     await fs.mkdir(uploadsDir, { recursive: true });
  24: 
  25:     const saved: Array<{ fileKey: string; url: string; originalName: string }> = [];
  26: 
  27:     for (const f of files) {
  28:       // Compatible con runtimes donde File no existe como clase
  29:       if (!f || typeof (f as any).arrayBuffer !== "function") continue;
  30: 
  31:       const file = f as unknown as File;
  32:       const bytes = await file.arrayBuffer();
  33:       const buffer = Buffer.from(bytes);
  34: 
  35:       const originalName = (file as any).name || "archivo";
  36:       const ext = path.extname(originalName) || ".jpg";
  37: 
  38:       const fileKey = `${crypto.randomUUID()}${ext}`;
  39:       const filePath = path.join(uploadsDir, fileKey);
  40: 
  41:       await fs.writeFile(filePath, buffer);
  42: 
  43:       saved.push({
  44:         fileKey,
  45:         url: `/uploads/${fileKey}`,
  46:         originalName,
  47:       });
  48:     }
  49: 
  50:     return NextResponse.json({ files: saved }, { status: 201 });
  51:   } catch (err: any) {
  52:     // ESTO ES CLAVE: ahora vas a ver el error real en terminal
  53:     console.error("UPLOAD ERROR REAL >>>", err);
  54:     return NextResponse.json(
  55:       { error: "Upload failed", detail: String(err?.message ?? err) },
  56:       { status: 500 }
  57:     );
  58:   }
  59: }
  60: 
  61: 

app/imprimir/page.tsx:
    1: "use client";
    2: 
    3: import { useState } from "react";
    4: 
    5: type UploadedFile = {
    6:   fileKey: string;
    7:   url: string;
    8:   originalName: string;
    9: };
   10: 
   11: type Finish = "BRILLO" | "MATE";
   12: 
   13: type Item = {
   14:   fileKey: string;
   15:   previewUrl: string;
   16:   originalName: string;
   17: 
   18:   size: string;
   19:   finish: Finish;
   20:   quantity: number;
   21:   unitPrice: number;
   22: 
   23:   selected: boolean;
   24: };
   25: 
   26: export default function ImprimirPage() {
   27:   const [customerName, setCustomerName] = useState("");
   28:   const [customerEmail, setCustomerEmail] = useState("");
   29:   const [customerPhone, setCustomerPhone] = useState("");
   30: 
   31:   const [items, setItems] = useState<Item[]>([]);
   32:   const [uploading, setUploading] = useState(false);
   33: 
   34:   // Config masiva (default pedido)
   35:   const [bulkSize, setBulkSize] = useState("10x15");
   36:   const [bulkFinish, setBulkFinish] = useState<Finish>("BRILLO");
   37:   const [bulkQty, setBulkQty] = useState(1);
   38:   const [bulkPrice, setBulkPrice] = useState(1500);
   39: 
   40:   const [loading, setLoading] = useState(false);
   41:   const [result, setResult] = useState<any>(null);
   42:   const [error, setError] = useState<string | null>(null);
   43: 
   44:   function setAllSelected(value: boolean) {
   45:     setItems((prev) => prev.map((it) => ({ ...it, selected: value })));
   46:   }
   47: 
   48:   function updateItem(index: number, patch: Partial<Item>) {
   49:     setItems((prev) => prev.map((it, i) => (i === index ? { ...it, ...patch } : it)));
   50:   }
   51: 
   52:   function applyBulkToSelected() {
   53:     const hasSelected = items.some((it) => it.selected);
   54:     if (!hasSelected) {
   55:       alert("Primero seleccioná al menos una foto (checkbox).");
   56:       return;
   57:     }
   58: 
   59:     setItems((prev) =>
   60:       prev.map((it) =>
   61:         it.selected
   62:           ? {
   63:               ...it,
   64:               size: bulkSize,
   65:               finish: bulkFinish,
   66:               quantity: bulkQty,
   67:               unitPrice: bulkPrice,
   68:             }
   69:           : it
   70:       )
   71:     );
   72:   }
   73: 
   74:   function removeItem(index: number) {
   75:     setItems((prev) => prev.filter((_, i) => i !== index));
   76:   }
   77: 
   78:   async function onPickFiles(e: React.ChangeEvent<HTMLInputElement>) {
   79:     const files = e.target.files;
   80:     if (!files || files.length === 0) return;
   81: 
   82:     setUploading(true);
   83:     setError(null);
   84:     setResult(null);
   85: 
   86:     try {
   87:       const formData = new FormData();
   88:       Array.from(files).forEach((f) => formData.append("files", f));
   89: 
   90:       const res = await fetch("/api/uploads", {
   91:         method: "POST",
   92:         body: formData,
   93:       });
   94: 
   95:       const data = await res.json();
   96:       if (!res.ok) throw new Error(data?.error || "Error subiendo archivos");
   97: 
   98:       const uploaded = (data.files as UploadedFile[]) || [];
   99: 
  100:       setItems((prev) => [
  101:         ...prev,
  102:         ...uploaded.map((u) => ({
  103:           fileKey: u.fileKey,
  104:           previewUrl: u.url,
  105:           originalName: u.originalName,
  106: 
  107:           size: bulkSize,
  108:           finish: bulkFinish,
  109:           quantity: bulkQty,
  110:           unitPrice: bulkPrice,
  111: 
  112:           selected: true, // ✅ por defecto quedan seleccionadas
  113:         })),
  114:       ]);
  115: 
  116:       // permitir seleccionar los mismos archivos otra vez si hace falta
  117:       e.target.value = "";
  118:     } catch (err: any) {
  119:       setError(err?.message || "Error");
  120:     } finally {
  121:       setUploading(false);
  122:     }
  123:   }
  124: 
  125:   async function createOrder() {
  126:     setLoading(true);
  127:     setError(null);
  128:     setResult(null);
  129: 
  130:     try {
  131:       if (items.length === 0) throw new Error("Primero subí al menos una foto.");
  132: 
  133:       // Validación rápida cliente-side para evitar errores tontos
  134:       for (let i = 0; i < items.length; i++) {
  135:         const it = items[i];
  136:         if (!it.fileKey) throw new Error(`Item #${i + 1}: falta fileKey`);
  137:         if (!it.size) throw new Error(`Item #${i + 1}: falta tamaño`);
  138:         if (!it.finish) throw new Error(`Item #${i + 1}: falta acabado`);
  139:         if (!Number.isFinite(it.quantity) || it.quantity < 1)
  140:           throw new Error(`Item #${i + 1}: cantidad inválida`);
  141:         if (!Number.isFinite(it.unitPrice) || it.unitPrice < 0)
  142:           throw new Error(`Item #${i + 1}: precio inválido`);
  143:       }
  144: 
  145:       const res = await fetch("/api/print-orders", {
  146:         method: "POST",
  147:         headers: { "Content-Type": "application/json" },
  148:         body: JSON.stringify({
  149:           customerName: customerName || undefined,
  150:           customerEmail: customerEmail || undefined,
  151:           customerPhone: customerPhone || undefined,
  152:           items: items.map((it) => ({
  153:             fileKey: it.fileKey,
  154:             originalName: it.originalName,
  155:             size: it.size,
  156:             finish: it.finish,
  157:             quantity: it.quantity,
  158:             unitPrice: it.unitPrice,
  159:           })),
  160:         }),
  161:       });
  162: 
  163:       const data = await res.json();
  164:       if (!res.ok) throw new Error(data?.error || "Error creando pedido");
  165: 
  166:       setResult(data);
  167:     } catch (e: any) {
  168:       setError(e?.message || "Error");
  169:     } finally {
  170:       setLoading(false);
  171:     }
  172:   }
  173: 
  174:   const totalPreview = items.reduce(
  175:     (acc, it) => acc + (Number(it.unitPrice) || 0) * (Number(it.quantity) || 0),
  176:     0
  177:   );
  178: 
  179:   return (
  180:     <main style={{ padding: 24, maxWidth: 1100 }}>
  181:       <h1>Imprimí tus fotos</h1>
  182:       <p style={{ opacity: 0.8, marginTop: 4 }}>
  183:         Subí todas las fotos juntas. Luego aplicá tamaño/acabado/cantidad en masa con “Aplicar a
  184:         seleccionadas”.
  185:       </p>
  186: 
  187:       <section style={{ marginTop: 16 }}>
  188:         <h2>1) Subir fotos</h2>
  189:         <input type="file" multiple accept="image/*" onChange={onPickFiles} />
  190:         {uploading && <p style={{ marginTop: 8 }}>Subiendo fotos...</p>}
  191:       </section>
  192: 
  193:       <section style={{ marginTop: 24 }}>
  194:         <h2>2) Datos del cliente (opcional)</h2>
  195:         <div style={{ display: "grid", gap: 8, maxWidth: 520 }}>
  196:           <input
  197:             placeholder="Nombre"
  198:             value={customerName}
  199:             onChange={(e) => setCustomerName(e.target.value)}
  200:           />
  201:           <input
  202:             placeholder="Email"
  203:             value={customerEmail}
  204:             onChange={(e) => setCustomerEmail(e.target.value)}
  205:           />
  206:           <input
  207:             placeholder="WhatsApp / Teléfono"
  208:             value={customerPhone}
  209:             onChange={(e) => setCustomerPhone(e.target.value)}
  210:           />
  211:         </div>
  212:       </section>
  213: 
  214:       <section style={{ marginTop: 24 }}>
  215:         <h2>3) Configuración masiva</h2>
  216: 
  217:         <div
  218:           style={{
  219:             display: "flex",
  220:             gap: 12,
  221:             flexWrap: "wrap",
  222:             alignItems: "center",
  223:             border: "1px solid #ddd",
  224:             borderRadius: 10,
  225:             padding: 12,
  226:           }}
  227:         >
  228:           <label>
  229:             Tamaño{" "}
  230:             <select value={bulkSize} onChange={(e) => setBulkSize(e.target.value)}>
  231:               <option value="10x15">10x15</option>
  232:               <option value="13x18">13x18</option>
  233:               <option value="15x20">15x20</option>
  234:             </select>
  235:           </label>
  236: 
  237:           <label>
  238:             Acabado{" "}
  239:             <select
  240:               value={bulkFinish}
  241:               onChange={(e) => setBulkFinish(e.target.value as Finish)}
  242:             >
  243:               <option value="BRILLO">Brillo</option>
  244:               <option value="MATE">Mate</option>
  245:             </select>
  246:           </label>
  247: 
  248:           <label>
  249:             Cantidad{" "}
  250:             <input
  251:               type="number"
  252:               min={1}
  253:               value={bulkQty}
  254:               onChange={(e) => setBulkQty(Number(e.target.value))}
  255:               style={{ width: 90 }}
  256:             />
  257:           </label>
  258: 
  259:           <label>
  260:             Precio unitario{" "}
  261:             <input
  262:               type="number"
  263:               min={0}
  264:               value={bulkPrice}
  265:               onChange={(e) => setBulkPrice(Number(e.target.value))}
  266:               style={{ width: 130 }}
  267:             />
  268:           </label>
  269: 
  270:           <button onClick={() => setAllSelected(true)}>Seleccionar todas</button>
  271:           <button onClick={() => setAllSelected(false)}>Deseleccionar todas</button>
  272:           <button onClick={applyBulkToSelected}>Aplicar a seleccionadas</button>
  273:         </div>
  274:       </section>
  275: 
  276:       <section style={{ marginTop: 24 }}>
  277:         <h2>4) Fotos del pedido ({items.length})</h2>
  278: 
  279:         {items.length === 0 ? (
  280:           <p>Subí fotos para empezar.</p>
  281:         ) : (
  282:           <div style={{ display: "grid", gap: 12 }}>
  283:             {items.map((it, idx) => (
  284:               <div
  285:                 key={it.fileKey}
  286:                 style={{
  287:                   border: "1px solid #ddd",
  288:                   borderRadius: 10,
  289:                   padding: 12,
  290:                   display: "grid",
  291:                   gridTemplateColumns: "120px 1fr",
  292:                   gap: 12,
  293:                   alignItems: "center",
  294:                 }}
  295:               >
  296:                 <img
  297:                   src={it.previewUrl}
  298:                   alt={it.originalName}
  299:                   style={{
  300:                     width: 120,
  301:                     height: 120,
  302:                     objectFit: "cover",
  303:                     borderRadius: 8,
  304:                     background: "#f3f3f3",
  305:                   }}
  306:                 />
  307: 
  308:                 <div style={{ display: "grid", gap: 10 }}>
  309:                   {/* ✅ Checkbox bien visible */}
  310:                   <div style={{ display: "flex", gap: 10, alignItems: "center" }}>
  311:                     <input
  312:                      type="checkbox"
  313:                      checked={it.selected}
  314:                      onChange={(e) => updateItem(idx, { selected: e.target.checked })}
  315:                      style={{
  316:                      width: 26,
  317:                       height: 26,
  318:                       cursor: "pointer",
  319:                       accentColor: "#000",
  320:                       outline: "2px solid #000",
  321:                       outlineOffset: "2px",
  322:                      background: "#fff",
  323:                    }}
  324:                     />
  325: 
  326:                     <b>{it.originalName}</b>
  327: 
  328:                     <button
  329:                       onClick={() => removeItem(idx)}
  330:                       style={{ marginLeft: "auto" }}
  331:                     >
  332:                       Eliminar
  333:                     </button>
  334:                   </div>
  335: 
  336:                   <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
  337:                     <label>
  338:                       Tamaño{" "}
  339:                       <select
  340:                         value={it.size}
  341:                         onChange={(e) => updateItem(idx, { size: e.target.value })}
  342:                       >
  343:                         <option value="10x15">10x15</option>
  344:                         <option value="13x18">13x18</option>
  345:                         <option value="15x20">15x20</option>
  346:                       </select>
  347:                     </label>
  348: 
  349:                     <label>
  350:                       Acabado{" "}
  351:                       <select
  352:                         value={it.finish}
  353:                         onChange={(e) =>
  354:                           updateItem(idx, { finish: e.target.value as Finish })
  355:                         }
  356:                       >
  357:                         <option value="BRILLO">Brillo</option>
  358:                         <option value="MATE">Mate</option>
  359:                       </select>
  360:                     </label>
  361: 
  362:                     <label>
  363:                       Cantidad{" "}
  364:                       <input
  365:                         type="number"
  366:                         min={1}
  367:                         value={it.quantity}
  368:                         onChange={(e) =>
  369:                           updateItem(idx, { quantity: Number(e.target.value) })
  370:                         }
  371:                         style={{ width: 90 }}
  372:                       />
  373:                     </label>
  374: 
  375:                     <label>
  376:                       Precio{" "}
  377:                       <input
  378:                         type="number"
  379:                         min={0}
  380:                         value={it.unitPrice}
  381:                         onChange={(e) =>
  382:                           updateItem(idx, { unitPrice: Number(e.target.value) })
  383:                         }
  384:                         style={{ width: 130 }}
  385:                       />
  386:                     </label>
  387:                   </div>
  388: 
  389:                   <div style={{ display: "flex", justifyContent: "space-between" }}>
  390:                     <span style={{ opacity: 0.7, fontSize: 12 }}>
  391:                       fileKey: {it.fileKey}
  392:                     </span>
  393:                     <b>
  394:                       Subtotal: {(Number(it.unitPrice) || 0) * (Number(it.quantity) || 0)}
  395:                     </b>
  396:                   </div>
  397:                 </div>
  398:               </div>
  399:             ))}
  400:           </div>
  401:         )}
  402: 
  403:         <p style={{ marginTop: 12 }}>
  404:           <b>Total estimado:</b> {totalPreview}
  405:         </p>
  406:       </section>
  407: 
  408:       <p style={{ marginTop: 12 }}>
  409:   DEBUG: items={items.length} | seleccionadas={items.filter(i => i.selected).length}
  410: </p>
  411: 
  412:       <section style={{ marginTop: 24 }}>
  413:         <button onClick={createOrder} disabled={loading}>
  414:           {loading ? "Creando pedido..." : "Crear pedido"}
  415:         </button>
  416: 
  417:         {error && (
  418:           <p style={{ marginTop: 12, color: "crimson" }}>
  419:             <b>Error:</b> {error}
  420:           </p>
  421:         )}
  422: 
  423:         {result && (
  424:           <div style={{ marginTop: 12, padding: 12, border: "1px solid #ddd" }}>
  425:             <h3>✅ Pedido creado</h3>
  426:             <p>
  427:               <b>ID:</b> {result.id}
  428:             </p>
  429:             <p>
  430:               <b>Total:</b> {result.total} {result.currency}
  431:             </p>
  432:             <pre style={{ whiteSpace: "pre-wrap" }}>
  433:               {JSON.stringify(result, null, 2)}
  434:             </pre>
  435:           </div>
  436:         )}
  437:       </section>
  438:     </main>
  439:   );
  440: }
  441: 

app/lab/pedidos/orders-table.tsx:
    1: "use client";
    2: 
    3: import { useMemo, useState } from "react";
    4: 
    5: const STATUS_OPTIONS = [
    6:   { value: "CREATED", label: "Creado" },
    7:   { value: "IN_PRODUCTION", label: "En producción" },
    8:   { value: "READY", label: "Listo" },
    9:   { value: "DELIVERED", label: "Entregado" },
   10:   { value: "CANCELED", label: "Cancelado" },
   11: ];
   12: 
   13: type OrderRow = {
   14:   id: number;
   15:   customerName: string | null;
   16:   createdAt: string;
   17:   itemsCount: number;
   18:   currency: string;
   19:   total: number;
   20:   status: string;
   21: };
   22: 
   23: export default function OrdersTable({ orders }: { orders: OrderRow[] }) {
   24:   const [selected, setSelected] = useState<Record<number, boolean>>({});
   25:   const [bulkStatus, setBulkStatus] = useState("IN_PRODUCTION");
   26:   const [busy, setBusy] = useState(false);
   27: 
   28:   const selectedIds = useMemo(
   29:     () => Object.entries(selected).filter(([, v]) => v).map(([k]) => Number(k)),
   30:     [selected]
   31:   );
   32: 
   33:   function toggleAll(checked: boolean) {
   34:     const next: Record<number, boolean> = {};
   35:     for (const o of orders) next[o.id] = checked;
   36:     setSelected(next);
   37:   }
   38: 
   39:   async function applyBulkStatus() {
   40:     if (selectedIds.length === 0) {
   41:       alert("No seleccionaste pedidos.");
   42:       return;
   43:     }
   44: 
   45:     try {
   46:       setBusy(true);
   47:       const res = await fetch("/api/print-orders/bulk-status", {
   48:         method: "PATCH",
   49:         headers: { "Content-Type": "application/json" },
   50:         body: JSON.stringify({ ids: selectedIds, status: bulkStatus }),
   51:       });
   52:       if (!res.ok) throw new Error(await res.text());
   53:       window.location.reload();
   54:     } catch (e) {
   55:       console.error(e);
   56:       alert("No se pudo aplicar el estado masivo. Mirá consola/terminal.");
   57:     } finally {
   58:       setBusy(false);
   59:     }
   60:   }
   61: 
   62:   return (
   63:     <div>
   64:       {/* Barra de acciones masivas */}
   65:       <div style={{ display: "flex", gap: 10, alignItems: "center", marginBottom: 12 }}>
   66:         <div style={{ fontSize: 13, color: "#444" }}>
   67:           Seleccionados: <strong>{selectedIds.length}</strong>
   68:         </div>
   69: 
   70:         <select
   71:           value={bulkStatus}
   72:           disabled={busy}
   73:           onChange={(e) => setBulkStatus(e.target.value)}
   74:           style={{ padding: "6px 8px", borderRadius: 6 }}
   75:         >
   76:           {STATUS_OPTIONS.map((o) => (
   77:             <option key={o.value} value={o.value}>
   78:               {o.label}
   79:             </option>
   80:           ))}
   81:         </select>
   82: 
   83:         <button
   84:           onClick={applyBulkStatus}
   85:           disabled={busy}
   86:           style={{
   87:             padding: "8px 12px",
   88:             borderRadius: 8,
   89:             border: "1px solid #111",
   90:             background: "white",
   91:             cursor: "pointer",
   92:           }}
   93:         >
   94:           Aplicar a seleccionados
   95:         </button>
   96:       </div>
   97: 
   98:       <div style={{ overflowX: "auto" }}>
   99:         <table style={{ width: "100%", borderCollapse: "collapse" }}>
  100:           <thead>
  101:             <tr>
  102:               <th style={th}>
  103:                 <input
  104:                   type="checkbox"
  105:                   onChange={(e) => toggleAll(e.target.checked)}
  106:                   aria-label="Seleccionar todos"
  107:                 />
  108:               </th>
  109:               <th style={th}>ID</th>
  110:               <th style={th}>Cliente</th>
  111:               <th style={th}>Fecha</th>
  112:               <th style={th}>Items</th>
  113:               <th style={th}>Total</th>
  114:               <th style={th}>Estado</th>
  115:               <th style={th}>Acciones</th>
  116:             </tr>
  117:           </thead>
  118:           <tbody>
  119:             {orders.map((o) => (
  120:               <tr key={o.id}>
  121:                 <td style={td}>
  122:                   <input
  123:                     type="checkbox"
  124:                     checked={!!selected[o.id]}
  125:                     onChange={(e) => setSelected((prev) => ({ ...prev, [o.id]: e.target.checked }))}
  126:                     aria-label={`Seleccionar pedido ${o.id}`}
  127:                   />
  128:                 </td>
  129:                 <td style={td}>#{o.id}</td>
  130:                 <td style={td}>{o.customerName || "-"}</td>
  131:                 <td style={td}>{new Date(o.createdAt).toLocaleString()}</td>
  132:                 <td style={td}>{o.itemsCount}</td>
  133:                 <td style={td}>
  134:                   {o.currency} {o.total}
  135:                 </td>
  136:                 <td style={td}>{o.status}</td>
  137:                 <td style={td}>
  138:                   <a
  139:                     href={`/api/print-orders/${o.id}/export`}
  140:                     target="_blank"
  141:                     rel="noreferrer"
  142:                     style={btn}
  143:                   >
  144:                     Descargar ZIP
  145:                   </a>
  146:                 </td>
  147:               </tr>
  148:             ))}
  149: 
  150:             {orders.length === 0 && (
  151:               <tr>
  152:                 <td style={td} colSpan={8}>
  153:                   No hay pedidos todavía.
  154:                 </td>
  155:               </tr>
  156:             )}
  157:           </tbody>
  158:         </table>
  159:       </div>
  160:     </div>
  161:   );
  162: }
  163: 
  164: const th: React.CSSProperties = {
  165:   textAlign: "left",
  166:   borderBottom: "1px solid #ddd",
  167:   padding: "10px 8px",
  168:   fontWeight: 600,
  169: };
  170: 
  171: const td: React.CSSProperties = {
  172:   borderBottom: "1px solid #eee",
  173:   padding: "10px 8px",
  174:   verticalAlign: "top",
  175: };
  176: 
  177: const btn: React.CSSProperties = {
  178:   display: "inline-block",
  179:   padding: "8px 10px",
  180:   border: "1px solid #111",
  181:   borderRadius: 8,
  182:   textDecoration: "none",
  183: };
  184: 

app/lab/pedidos/page.tsx:
   1: import Link from "next/link";
   2: import { prisma } from "@/lib/prisma";
   3: import OrdersTable from "./orders-table";
   4: 
   5: export const dynamic = "force-dynamic";
   6: 
   7: export default async function LabPedidosPage() {
   8:   const orders = await prisma.printOrder.findMany({
   9:     orderBy: { createdAt: "desc" },
  10:     take: 50,
  11:     include: { items: true },
  12:   });
  13: 
  14:   const rows = orders.map((o) => ({
  15:     id: o.id,
  16:     customerName: o.customerName,
  17:     createdAtText: new Intl.DateTimeFormat("es-AR", {
  18:   dateStyle: "short",
  19:   timeStyle: "medium",
  20: }).format(o.createdAt),
  21:     itemsCount: o.items.length,
  22:     currency: o.currency,
  23:     total: o.total,
  24:     status: o.status,
  25:   }));
  26: 
  27:   return (
  28:     <main style={{ padding: 24, fontFamily: "sans-serif" }}>
  29:       <h1 style={{ fontSize: 22, marginBottom: 8 }}>Laboratorio — Pedidos</h1>
  30:       <p style={{ marginTop: 0, marginBottom: 16, color: "#444" }}>
  31:         Seleccioná pedidos para cambiar estado en bloque.
  32:       </p>
  33: 
  34:       <OrdersTable orders={rows} />
  35: 
  36:       <div style={{ marginTop: 18 }}>
  37:         <Link href="/imprimir">← Volver a /imprimir</Link>
  38:       </div>
  39:     </main>
  40:   );
  41: }
  42: 

assets/fonts/Roboto-Regular.ttf:
     1: 
     2: 
     3: 
     4: 
     5: 
     6: 
     7: 
     8: 
     9: <!DOCTYPE html>
    10: <html
    11:   lang="en"
    12:   
    13:   data-color-mode="auto" data-light-theme="light" data-dark-theme="dark"
    14:   data-a11y-animated-images="system" data-a11y-link-underlines="true"
    15:   
    16:   >
    17: 
    18: 
    19: 
    20: 
