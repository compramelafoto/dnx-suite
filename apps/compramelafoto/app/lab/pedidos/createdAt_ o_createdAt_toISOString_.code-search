app/page.tsx:
    1: "use client";
    2: 
    3: import { useState } from "react";
    4: 
    5: type UploadedFile = {
    6:   fileKey: string;
    7:   url: string;
    8:   originalName: string;
    9: };
   10: 
   11: type Finish = "BRILLO" | "MATE";
   12: 
   13: type Item = {
   14:   fileKey: string;
   15:   previewUrl: string;
   16:   originalName: string;
   17: 
   18:   size: string;
   19:   finish: Finish;
   20:   quantity: number;
   21:   unitPrice: number;
   22: 
   23:   selected: boolean;
   24: };
   25: 
   26: export default function ImprimirPage() {
   27:   const [customerName, setCustomerName] = useState("");
   28:   const [customerEmail, setCustomerEmail] = useState("");
   29:   const [customerPhone, setCustomerPhone] = useState("");
   30: 
   31:   const [items, setItems] = useState<Item[]>([]);
   32:   const [uploading, setUploading] = useState(false);
   33: 
   34:   // Config masiva (default: 10x15 + BRILLO)
   35:   const [bulkSize, setBulkSize] = useState("10x15");
   36:   const [bulkFinish, setBulkFinish] = useState<Finish>("BRILLO");
   37:   const [bulkQty, setBulkQty] = useState(1);
   38:   const [bulkPrice, setBulkPrice] = useState(1500);
   39: 
   40:   const [loading, setLoading] = useState(false);
   41:   const [result, setResult] = useState<any>(null);
   42:   const [error, setError] = useState<string | null>(null);
   43: 
   44:   function setAllSelected(value: boolean) {
   45:     setItems((prev) => prev.map((it) => ({ ...it, selected: value })));
   46:   }
   47: 
   48:   function updateItem(index: number, patch: Partial<Item>) {
   49:     setItems((prev) =>
   50:       prev.map((it, i) => (i === index ? { ...it, ...patch } : it))
   51:     );
   52:   }
   53: 
   54:   function applyBulkToSelected() {
   55:     setItems((prev) =>
   56:       prev.map((it) =>
   57:         it.selected
   58:           ? {
   59:               ...it,
   60:               size: bulkSize,
   61:               finish: bulkFinish,
   62:               quantity: bulkQty,
   63:               unitPrice: bulkPrice,
   64:             }
   65:           : it
   66:       )
   67:     );
   68:   }
   69: 
   70:   async function onPickFiles(e: React.ChangeEvent<HTMLInputElement>) {
   71:     const files = e.target.files;
   72:     if (!files || files.length === 0) return;
   73: 
   74:     setUploading(true);
   75:     setError(null);
   76:     setResult(null);
   77: 
   78:     try {
   79:       const formData = new FormData();
   80:       Array.from(files).forEach((f) => formData.append("files", f));
   81: 
   82:       const res = await fetch("/api/uploads", {
   83:         method: "POST",
   84:         body: formData,
   85:       });
   86: 
   87:       const data = await res.json();
   88:       if (!res.ok) throw new Error(data?.error || "Error subiendo archivos");
   89: 
   90:       const uploaded = (data.files as UploadedFile[]) || [];
   91: 
   92:       setItems((prev) => [
   93:         ...prev,
   94:         ...uploaded.map((u) => ({
   95:           fileKey: u.fileKey,
   96:           previewUrl: u.url,
   97:           originalName: u.originalName,
   98: 
   99:           size: bulkSize,
  100:           finish: bulkFinish,
  101:           quantity: bulkQty,
  102:           unitPrice: bulkPrice,
  103: 
  104:           selected: true,
  105:         })),
  106:       ]);
  107: 
  108:       // permite volver a elegir los mismos archivos si quiere
  109:       e.target.value = "";
  110:     } catch (err: any) {
  111:       setError(err?.message || "Error");
  112:     } finally {
  113:       setUploading(false);
  114:     }
  115:   }
  116: 
  117:   async function createOrder() {
  118:     setLoading(true);
  119:     setError(null);
  120:     setResult(null);
  121: 
  122:     try {
  123:       if (items.length === 0) throw new Error("Primero subí al menos una foto.");
  124: 
  125:       const res = await fetch("/api/print-orders", {
  126:         method: "POST",
  127:         headers: { "Content-Type": "application/json" },
  128:         body: JSON.stringify({
  129:           customerName: customerName || undefined,
  130:           customerEmail: customerEmail || undefined,
  131:           customerPhone: customerPhone || undefined,
  132:           items: items.map((it) => ({
  133:             fileKey: it.fileKey,
  134:             originalName: it.originalName,
  135:             size: it.size,
  136:             finish: it.finish,
  137:             quantity: it.quantity,
  138:             unitPrice: it.unitPrice,
  139:           })),
  140:         }),
  141:       });
  142: 
  143:       const data = await res.json();
  144:       if (!res.ok) throw new Error(data?.error || "Error creando pedido");
  145: 
  146:       setResult(data);
  147:     } catch (e: any) {
  148:       setError(e?.message || "Error");
  149:     } finally {
  150:       setLoading(false);
  151:     }
  152:   }
  153: 
  154:   const totalPreview = items.reduce(
  155:     (acc, it) => acc + (Number(it.unitPrice) || 0) * (Number(it.quantity) || 0),
  156:     0
  157:   );
  158: 
  159:   return (
  160:     <main style={{ padding: 24, maxWidth: 1100 }}>
  161:       <h1>Imprimí tus fotos</h1>
  162: 
  163:       <section style={{ marginTop: 16 }}>
  164:         <h2>1) Subir fotos</h2>
  165:         <input type="file" multiple accept="image/*" onChange={onPickFiles} />
  166:         {uploading && <p>Subiendo fotos...</p>}
  167:       </section>
  168: 
  169:       <section style={{ marginTop: 24 }}>
  170:         <h2>2) Datos del cliente (opcional)</h2>
  171:         <div style={{ display: "grid", gap: 8 }}>
  172:           <input
  173:             placeholder="Nombre"
  174:             value={customerName}
  175:             onChange={(e) => setCustomerName(e.target.value)}
  176:           />
  177:           <input
  178:             placeholder="Email"
  179:             value={customerEmail}
  180:             onChange={(e) => setCustomerEmail(e.target.value)}
  181:           />
  182:           <input
  183:             placeholder="WhatsApp / Teléfono"
  184:             value={customerPhone}
  185:             onChange={(e) => setCustomerPhone(e.target.value)}
  186:           />
  187:         </div>
  188:       </section>
  189: 
  190:       <section style={{ marginTop: 24 }}>
  191:         <h2>3) Configuración masiva</h2>
  192: 
  193:         <div style={{ display: "flex", gap: 12, flexWrap: "wrap", alignItems: "center" }}>
  194:           <label>
  195:             Tamaño{" "}
  196:             <select value={bulkSize} onChange={(e) => setBulkSize(e.target.value)}>
  197:               <option value="10x15">10x15</option>
  198:               <option value="13x18">13x18</option>
  199:               <option value="15x20">15x20</option>
  200:             </select>
  201:           </label>
  202: 
  203:           <label>
  204:             Acabado{" "}
  205:             <select
  206:               value={bulkFinish}
  207:               onChange={(e) => setBulkFinish(e.target.value as Finish)}
  208:             >
  209:               <option value="BRILLO">Brillo</option>
  210:               <option value="MATE">Mate</option>
  211:             </select>
  212:           </label>
  213: 
  214:           <label>
  215:             Cantidad{" "}
  216:             <input
  217:               type="number"
  218:               min={1}
  219:               value={bulkQty}
  220:               onChange={(e) => setBulkQty(Number(e.target.value))}
  221:               style={{ width: 90 }}
  222:             />
  223:           </label>
  224: 
  225:           <label>
  226:             Precio unitario{" "}
  227:             <input
  228:               type="number"
  229:               min={0}
  230:               value={bulkPrice}
  231:               onChange={(e) => setBulkPrice(Number(e.target.value))}
  232:               style={{ width: 120 }}
  233:             />
  234:           </label>
  235: 
  236:           <button onClick={() => setAllSelected(true)}>Seleccionar todas</button>
  237:           <button onClick={() => setAllSelected(false)}>Deseleccionar todas</button>
  238:           <button onClick={applyBulkToSelected}>Aplicar a seleccionadas</button>
  239:         </div>
  240:       </section>
  241: 
  242:       <section style={{ marginTop: 24 }}>
  243:         <h2>4) Fotos del pedido ({items.length})</h2>
  244: 
  245:         {items.length === 0 ? (
  246:           <p>Subí fotos para empezar.</p>
  247:         ) : (
  248:           <div style={{ display: "grid", gap: 12 }}>
  249:             {items.map((it, idx) => (
  250:               <div
  251:                 key={it.fileKey}
  252:                 style={{
  253:                   border: "1px solid #ddd",
  254:                   borderRadius: 10,
  255:                   padding: 12,
  256:                   display: "grid",
  257:                   gridTemplateColumns: "120px 1fr",
  258:                   gap: 12,
  259:                   alignItems: "center",
  260:                 }}
  261:               >
  262:                 <img
  263:                   src={it.previewUrl}
  264:                   alt={it.originalName}
  265:                   style={{ width: 120, height: 120, objectFit: "cover", borderRadius: 8 }}
  266:                 />
  267: 
  268:                 <div style={{ display: "grid", gap: 8 }}>
  269:                   <label style={{ display: "flex", gap: 8, alignItems: "center" }}>
  270:                     <input
  271:                       type="checkbox"
  272:                       checked={it.selected}
  273:                       onChange={(e) => updateItem(idx, { selected: e.target.checked })}
  274:                     />
  275:                     <b>{it.originalName}</b>
  276:                   </label>
  277: 
  278:                   <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
  279:                     <label>
  280:                       Tamaño{" "}
  281:                       <select
  282:                         value={it.size}
  283:                         onChange={(e) => updateItem(idx, { size: e.target.value })}
  284:                       >
  285:                         <option value="10x15">10x15</option>
  286:                         <option value="13x18">13x18</option>
  287:                         <option value="15x20">15x20</option>
  288:                       </select>
  289:                     </label>
  290: 
  291:                     <label>
  292:                       Acabado{" "}
  293:                       <select
  294:                         value={it.finish}
  295:                         onChange={(e) => updateItem(idx, { finish: e.target.value as Finish })}
  296:                       >
  297:                         <option value="BRILLO">Brillo</option>
  298:                         <option value="MATE">Mate</option>
  299:                       </select>
  300:                     </label>
  301: 
  302:                     <label>
  303:                       Cantidad{" "}
  304:                       <input
  305:                         type="number"
  306:                         min={1}
  307:                         value={it.quantity}
  308:                         onChange={(e) =>
  309:                           updateItem(idx, { quantity: Number(e.target.value) })
  310:                         }
  311:                         style={{ width: 90 }}
  312:                       />
  313:                     </label>
  314: 
  315:                     <label>
  316:                       Precio{" "}
  317:                       <input
  318:                         type="number"
  319:                         min={0}
  320:                         value={it.unitPrice}
  321:                         onChange={(e) =>
  322:                           updateItem(idx, { unitPrice: Number(e.target.value) })
  323:                         }
  324:                         style={{ width: 120 }}
  325:                       />
  326:                     </label>
  327:                   </div>
  328: 
  329:                   <div style={{ display: "flex", justifyContent: "space-between" }}>
  330:                     <span style={{ opacity: 0.8 }}>fileKey: {it.fileKey}</span>
  331:                     <b>
  332:                       Subtotal: {(Number(it.unitPrice) || 0) * (Number(it.quantity) || 0)}
  333:                     </b>
  334:                   </div>
  335:                 </div>
  336:               </div>
  337:             ))}
  338:           </div>
  339:         )}
  340: 
  341:         <p style={{ marginTop: 12 }}>
  342:           <b>Total estimado:</b> {totalPreview}
  343:         </p>
  344:       </section>
  345: 
  346:       <section style={{ marginTop: 24 }}>
  347:         <button onClick={createOrder} disabled={loading}>
  348:           {loading ? "Creando pedido..." : "Crear pedido"}
  349:         </button>
  350: 
  351:         {error && (
  352:           <p style={{ marginTop: 12, color: "crimson" }}>
  353:             <b>Error:</b> {error}
  354:           </p>
  355:         )}
  356: 
  357:         {result && (
  358:           <div style={{ marginTop: 12, padding: 12, border: "1px solid #ddd" }}>
  359:             <h3>✅ Pedido creado</h3>
  360:             <p>
  361:               <b>ID:</b> {result.id}
  362:             </p>
  363:             <p>
  364:               <b>Total:</b> {result.total} {result.currency}
  365:             </p>
  366:             <pre style={{ whiteSpace: "pre-wrap" }}>
  367:               {JSON.stringify(result, null, 2)}
  368:             </pre>
  369:           </div>
  370:         )}
  371:       </section>
  372:     </main>
  373:   );
  374: }
  375: 

app/a/[id]/page.tsx:
   1: // app/a/[id]/page.tsx
   2: import { prisma } from "@/lib/prisma";
   3: import { notFound } from "next/navigation";
   4: 
   5: export default async function AlbumPage({ params }: { params: any }) {
   6:   // En Next (según versión), params puede venir como Promise: lo resolvemos seguro.
   7:   const resolvedParams = await Promise.resolve(params);
   8: 
   9:   const albumId = Number.parseInt(String(resolvedParams?.id), 10);
  10:   if (!Number.isFinite(albumId)) return notFound();
  11: 
  12:   const album = await prisma.album.findUnique({
  13:     where: { id: albumId },
  14:     // Si te da error por relación, lo sacamos o lo ajustamos al nombre real.
  15:     include: { photos: true },
  16:   });
  17: 
  18:   if (!album) return notFound();
  19: 
  20:   return (
  21:     <main style={{ padding: 24 }}>
  22:       <h1>{album.title}</h1>
  23: 
  24:       <p>
  25:         <b>ID:</b> {album.id}
  26:       </p>
  27: 
  28:       <p>
  29:         <b>Ubicación:</b> {album.location ?? "-"}
  30:       </p>
  31: 
  32:       <hr style={{ margin: "16px 0" }} />
  33: 
  34:       <h2>Fotos ({album.photos.length})</h2>
  35: 
  36:       {album.photos.length ? (
  37:         <ul>
  38:           {album.photos.map((p) => (
  39:             <li key={p.id}>Foto #{p.id}</li>
  40:           ))}
  41:         </ul>
  42:       ) : (
  43:         <p>No hay fotos cargadas en este álbum.</p>
  44:       )}
  45:     </main>
  46:   );
  47: }
