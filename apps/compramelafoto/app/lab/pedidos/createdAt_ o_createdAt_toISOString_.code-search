app/a/[slug]/page.tsx:
   1: // app/a/[slug]/page.tsx
   2: import { prisma } from "@/lib/prisma";
   3: 
   4: type PageProps = {
   5:   params: { slug: string };
   6: };
   7: 
   8: export default async function AlbumPage({ params }: PageProps) {
   9:   const albumId = Number.parseInt(params.slug, 10);
  10: 
  11:   const albumsCount = await prisma.album.count();
  12:   const firstAlbums = await prisma.album.findMany({
  13:     take: 5,
  14:     orderBy: { id: "asc" },
  15:   });
  16: 
  17:   const album = Number.isFinite(albumId)
  18:     ? await prisma.album.findUnique({
  19:         where: { id: albumId },
  20:         // si esto da error por relación, lo sacamos
  21:         include: { photos: true },
  22:       })
  23:     : null;
  24: 
  25:   return (
  26:     <main style={{ padding: 24 }}>
  27:       <h1>Debug /a/[slug]</h1>
  28: 
  29:       <p>
  30:         <b>params.slug:</b> [{String(params.slug)}]
  31: 
  32:       </p>
  33:       <p>
  34:         <b>albumId parseado:</b> {String(albumId)}
  35:       </p>
  36: 
  37:       <hr style={{ margin: "16px 0" }} />
  38: 
  39:       <p>
  40:         <b>albumsCount (desde la app):</b> {albumsCount}
  41:       </p>
  42: 
  43:       <h2>Primeros álbumes</h2>
  44:       {firstAlbums.length ? (
  45:         <ul>
  46:           {firstAlbums.map((a) => (
  47:             <li key={a.id}>
  48:               id={a.id} — title={a.title}
  49:             </li>
  50:           ))}
  51:         </ul>
  52:       ) : (
  53:         <p>No hay álbumes en esta DB (según la app).</p>
  54:       )}
  55: 
  56:       <hr style={{ margin: "16px 0" }} />
  57: 
  58:       <h2>Resultado findUnique({`id: ${albumId}`})</h2>
  59:       {album ? (
  60:         <>
  61:           <p>
  62:             ✅ Encontrado: <b>{album.title}</b> (id {album.id})
  63:           </p>
  64:           {"photos" in album ? (
  65:             <p>Fotos: {(album as any).photos?.length ?? 0}</p>
  66:           ) : null}
  67:         </>
  68:       ) : (
  69:         <p>❌ No encontrado (album es null)</p>
  70:       )}
  71:     </main>
  72:   );
  73: }
