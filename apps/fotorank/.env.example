# Copia a .env.local y completa según entorno.
# La URL debe coincidir con packages/db.
DATABASE_URL="postgresql://user:password@localhost:5432/dnx_suite"
DIRECT_URL="postgresql://user:password@localhost:5432/dnx_suite"

# URL canónica de la app (server-side).
# Convención por entorno:
# - local:      http://localhost:3000
# - staging:    https://fotorank.staging.dnxsuite.com
# - producción: https://fotorank.dnxsuite.com
APP_URL="http://localhost:3000"

# URL pública usada por metadata, links y cliente.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_FOTORANK_URL="http://localhost:3000"

# URL de auth (compatibilidad). Mantener igual a APP_URL.
AUTH_URL="http://localhost:3000"

# Secret de auth/sesión.
AUTH_SECRET=""

# Cookie compartida entre subdominios (SSO).
# - local: dejar vacío (host-only)
# - staging: .staging.dnxsuite.com
# - producción: .dnxsuite.com
COOKIE_DOMAIN=""

# Google OAuth (solo si habilitás login Google en Fotorank).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Callback opcional explícito; por defecto: ${APP_URL}/api/auth/google/callback
GOOGLE_REDIRECT_URI=""

# En desarrollo, el repo incluye .env.development con NEXT_PUBLIC_E2E_JUDGE_BIO=1
# para Playwright. Si lo quitás, los tests de crear jurado pueden fallar en la bio.
