model ReferralPayoutRequest {
  id             Int       @id @default(autoincrement())
  referrerUserId Int
  amountCents    Int
  status         String    @default("PENDING") // PENDING | PAID | CANCELLED
  requestedAt    DateTime  @default(now())
  paidAt         DateTime?
  paidByUserId   Int?      // admin que marcó como pagado
  externalRef    String?   // ref de MP o transferencia
  notes          String?
  referrerUser   User      @relation("ReferralPayoutRequests", fields: [referrerUserId], references: [id], onDelete: Cascade)
  paidByUser     User?     @relation("ReferralPayoutsMarkedBy", fields: [paidByUserId], references: [id], onDelete: SetNull)

  @@index([referrerUserId])
  @@index([status])
}

/// Fee de plataforma que no se cobró en el pago (ej. preferencia creada con fee=0 por bug).
/// Sirve para recuperar manualmente o descontar en un futuro payout.
model UncollectedPlatformFee {
  id          Int       @id @default(autoincrement())
  orderType   String    // "PRINT_ORDER" | "ALBUM_ORDER"
  orderId     Int
  amountCents Int
  status      String    @default("PENDING") // PENDING | RECOVERED | WAIVED
  notes       String?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  @@unique([orderType, orderId])
  @@index([status])
  @@index([orderType, orderId])
}

enum EmailQueueStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum TokenPurpose {
  VERIFY_EMAIL
  CREATE_ACCOUNT
}

enum ZipJobType {
  ORDER_DOWNLOAD
  ALBUM_DOWNLOAD
  CUSTOM_PHOTOS
}

enum ZipJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
}

enum DownloadTokenType {
  CLIENT_DIGITAL
  LAB_PRINT
}

// --- AAIP: Solicitudes ARCO (acceso, rectificación, supresión, etc.) ---
enum PrivacyRequestType {
  ACCESO
  RECTIFICACION
  SUPRESION
  OCULTAR_FOTO
  BAJA_MARKETING
  DESACTIVAR_BIOMETRIA
}

enum PrivacyRequestRelationship {
  TITULAR
  PADRE_MADRE_TUTOR
}

enum PrivacyRequestStatus {
  RECEIVED
  IN_REVIEW
  RESOLVED
  REJECTED
}

model PrivacyRequest {
  id           Int                      @id @default(autoincrement())
  type         PrivacyRequestType
  fullName     String
  email        String
  phone        String?
  relationship PrivacyRequestRelationship @default(TITULAR)
  description  String?                   @db.Text
  albumId      Int?
  photoId      Int?
  status       PrivacyRequestStatus      @default(RECEIVED)
  internalNote String?                   @db.Text
  metadata     Json?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

/// Auditoría de eventos de privacidad (consentimientos facial, etc.)
model PrivacyEvent {
  id        Int      @id @default(autoincrement())
  eventType String
  userId    Int?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
}

// --- Comunidad: directorio "Para fotógrafos" + "Proveedores" ---
enum CommunityProfileType {
  PHOTOGRAPHER_SERVICE
  EVENT_VENDOR
}

enum CommunityProfileStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum CommunitySubmissionStatus {
  PENDING
  APPLIED
  CONFLICT
}

model CommunityProfile {
  id                  String    @id @default(cuid())
  type                CommunityProfileType
  status              CommunityProfileStatus @default(PENDING)
  name                String
  slug                String
  description         String?
  province            String?
  city                String?
  address             String?
  latitude            Float?
  longitude           Float?
  email               String?
  emailNormalized     String?
  whatsapp            String?
  whatsappNormalized  String?
  website             String?
  instagram           String?
  facebook            String?
  tiktok              String?
  youtube             String?
  logoUrl             String?
  contactName         String?
  isFeatured         Boolean   @default(false)
  createdAt           DateTime @default(now())
  updatedAt          DateTime @updatedAt
  categories         CommunityProfileCategory[]
  workReferences     CommunityWorkReference[]

  @@unique([type, slug])
  @@unique([type, emailNormalized])
  @@unique([type, whatsappNormalized])
  @@index([type, status])
  @@index([type, province])
  @@index([type, city])
  @@index([province, city])
}

model CommunityCategory {
  id        Int      @id @default(autoincrement())
  type      CommunityProfileType
  name      String
  slug      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  profiles  CommunityProfileCategory[]

  @@unique([type, slug])
}

model CommunityProfileCategory {
  profileId   String
  categoryId  Int
  profile     CommunityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  category    CommunityCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([profileId, categoryId])
}

model CommunityWorkReference {
  id        Int      @id @default(autoincrement())
  profileId String
  label     String
  createdAt DateTime @default(now())
  profile   CommunityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model CommunitySubmission {
  id                 Int                      @id @default(autoincrement())
  type               CommunityProfileType
  status             CommunitySubmissionStatus @default(PENDING)
  payload            Json
  matchedProfileId   String?
  conflictProfileIds String[]                @default([])
  createdAt          DateTime                @default(now())
}

// ========== ANTIFRAUDE ==========

/// * Auditoría de pedidos: eventos de visibilidad, pago, liberación de datos
model OrderAuditLog {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  actorUserId     Int?
  actorRole       String?
  targetOrderType String    /// "PRINT_ORDER" | "ALBUM_ORDER"
  targetOrderId   Int
  targetAlbumId   Int?
  eventType       String    /// ORDER_CREATED, PAYMENT_APPROVED, CUSTOMER_DATA_RELEASED, etc.
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  riskScoreSnapshot Int?

  @@index([targetOrderType, targetOrderId])
  @@index([actorUserId])
  @@index([eventType])
  @@index([createdAt])
}

/// * Webhook de MP procesado (idempotencia)
model WebhookEvent {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  paymentId     String   @unique
  orderId       Int?
  orderType     String?
  status        String?
  externalRef   String?  /// external_reference de MP para reconciliación
  processedAt   DateTime @default(now())
  payloadHash   String?  /// Hash del payload para detectar duplicados
  rawPayload    Json?    /// Payload crudo para debugging (opcional, puede ser grande)

  @@index([paymentId])
  @@index([orderId, orderType])
}

/// * Alerta de fraude generada por reglas determinísticas
model FraudAlert {
  id            Int       @id @default(autoincrement())
  createdAt     DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedBy   Int?
  userId       Int?
  labId        Int?
  ruleCode     String    /// PENDING_ORDERS_HIGH, VIEWS_NON_PAID, etc.
  severity     String    /// INFO, WARNING, CRITICAL
  riskScore    Int?      /// 0-100
  metadata     Json?
  status       String    @default("OPEN") /// OPEN, ACKNOWLEDGED, RESOLVED, FALSE_POSITIVE

  @@index([userId])
  @@index([labId])
  @@index([ruleCode])
  @@index([status])
  @@index([createdAt])
}

/// * Restricción aplicada a cuenta (fotógrafo o lab)
model AccountRestriction {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  userId      Int?
  labId       Int?
  restrictionType String /// WARNING, LIMITED_VISIBILITY, MANUAL_REVIEW, TEMP_SUSPENSION, FULL_SUSPENSION
  reason      String?
  appliedBy   Int?      /// Admin que aplicó
  metadata    Json?

  @@index([userId])
  @@index([labId])
  @@index([restrictionType])
  @@index([expiresAt])
}
