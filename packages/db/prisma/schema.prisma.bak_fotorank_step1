model ReferralCode {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  ownerUserId  Int       @unique
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  ownerUser    User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  attributions ReferralAttribution[]

  @@index([code])
  @@index([ownerUserId])
}

model ReferralAttribution {
  id             Int           @id @default(autoincrement())
  referralCodeId Int
  referrerUserId Int
  referredUserId Int
  startsAt       DateTime
  endsAt         DateTime
  status         ReferralStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  referrerUser   User         @relation("ReferralReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referredUser   User         @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  earnings       ReferralEarning[]

  @@unique([referredUserId])
  @@index([referrerUserId])
  @@index([referralCodeId])
  @@index([status, endsAt])
}

model ReferralEarning {
  id                  Int                @id @default(autoincrement())
  attributionId       Int
  paymentId           String?            // id de MP o identificador del pago
  saleRef             String?            // orderId / purchaseId para trazabilidad
  platformFeeCents    Int                // fee original de plataforma
  referralAmountCents Int                // 50% pagado al referrer
  platformNetCents    Int                @default(0) // fee que recibe la plataforma (0 = legacy)
  createdAt           DateTime           @default(now())
  paidOutAt           DateTime?           // cuando se pagó al referidor (solicitud de cobro)
  reversedAt          DateTime?           // reembolso/contracargo: la comisión no cuenta para el referidor
  appliedAt           DateTime?           // cuando se usó para descontar del fee de una venta propia del referidor
  appliedToOrderId    Int?                // orderId de la venta donde se aplicó
  appliedToOrderType  String?            // PRINT_ORDER | ALBUM_ORDER
  attribution         ReferralAttribution @relation(fields: [attributionId], references: [id], onDelete: Cascade)

  @@index([attributionId])
  @@index([createdAt])
}

