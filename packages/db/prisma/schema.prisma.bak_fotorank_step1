generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model User {
  id                                Int                       @id @default(autoincrement())
  email                             String                    @unique
  password                          String?
  role                              Role                      @default(PHOTOGRAPHER)
  name                              String?
  createdAt                         DateTime                  @default(now())
  handler                           String?                   @unique
  isPublicPageEnabled               Boolean                   @default(false)
  logoUrl                           String?
  preferredLabId                    Int?
  primaryColor                      String?
  profitMarginPercent               Float?
  publicPageHandler                 String?                   @unique
  secondaryColor                    String?
  fontColor                         String?
  address                           String?
  birthDate                         DateTime?
  city                              String?
  /// Ubicación para eventos cerca e invitaciones por proximidad (km)
  latitude                          Float?
  longitude                         Float?
  companyName                       String?
  companyOwner                      String?
  country                           String?
  cuit                              String?
  phone                             String?
  province                          String?
  postalCode                        String?
  enableAlbumsPage                  Boolean                   @default(false)
  enablePrintPage                   Boolean                   @default(false)
  showCarnetPrints                  Boolean                   @default(false)
  showPolaroidPrints                Boolean                   @default(false)
  tertiaryColor                     String?
  headerBackgroundColor             String?
  footerBackgroundColor             String?
  heroBackgroundColor               String?
  pageBackgroundColor               String?
  companyAddress                    String?
  facebook                          String?
  instagram                         String?
  tiktok                            String?
  website                           String?
  whatsapp                          String?
  digitalDiscount10Plus             Float?
  digitalDiscount20Plus             Float?
  digitalDiscount5Plus              Float?
  digitalDiscountsEnabled           Boolean                   @default(false)
  defaultDigitalPhotoPrice          Int?
  mpAccessToken                     String?
  mpConnectedAt                     DateTime?
  mpRefreshToken                    String?
  mpUserId                          String?
  blockedAt                         DateTime?
  blockedReason                     String?
  isBlocked                         Boolean                   @default(false)
  lastLoginAt                       DateTime?
  tags                              String[]                  @default([])
  passwordResetExpires              DateTime?
  passwordResetToken                String?                   @unique
  googleId                          String?                   @unique
  emailVerifiedAt                   DateTime?
  platformCommissionPercentOverride Int?
  /// CBU o Alias CBU para transferencias de comisiones por referidos
  cbu                               String?
  /// Titular de la cuenta (para transferencias de comisiones por referidos)
  cbuTitular                        String?
  adminLogs                         AdminLog[]                @relation("AdminLogActor")
  sentMessages                      AdminMessage[]            @relation("MessageSender")
  messageThreads                    AdminMessageThread[]      @relation("UserMessageThreads")
  albums                            Album[]
  albumsCreated                     Album[]                   @relation("AlbumCreator")
  albumAccesses                     AlbumAccess[]
  albumExtensionsRequested          AlbumExtension[]          @relation("AlbumExtensionRequestedBy")
  albumInvitationsAccepted          AlbumInvitation[]         @relation("AlbumInvitationAcceptedBy")
  albumInvitationsSent              AlbumInvitation[]         @relation("AlbumInvitationInvitedBy")
  contactMessages                   ContactMessage[]          @relation("ContactMessagePhotographer")
  lab                               Lab?                      @relation("LabUser")
  passwordResetTokens               PasswordResetToken[]
  uploadedPhotos                    Photo[]                   @relation("PhotoUploader")
  products                          PhotographerProduct[]
  clientOrders                      PrintOrder[]              @relation("ClientOrders")
  printOrders                       PrintOrder[]              @relation("PhotographerOrders")
  printOrderStatusHistory           PrintOrderStatusHistory[] @relation("PrintOrderStatusHistoryChangedBy")
  removalRequestsDecided            RemovalRequest[]          @relation("RemovalRequestDecider")
  removalRequests                   RemovalRequest[]
  supportMessages                   SupportMessage[]          @relation("SupportMessageAuthor")
  supportTickets                    SupportTicket[]           @relation("SupportTicketAssignedTo")
  termsAcceptances                  TermsAcceptance[]         @relation("UserTermsAcceptance")
  preferredLab                      Lab?                      @relation("PhotographerPreferredLab", fields: [preferredLabId], references: [id])
  loginDevices                      UserLoginDevice[]
  buyerOrders                       Order[]                   @relation("OrderBuyerUser")
  eventMemberships                  EventMember[]
  eventInvitations                 EventInvitation[]
  createdEvents                    Event[]                    @relation("EventCreator")
  dashboardNotifications            DashboardNotification[]
  organizerDownloadAllowances       OrganizerDownloadAllowance[]
  albumCollaborations               AlbumCollaborator[]
  referralCodeOwned                 ReferralCode?
  referralAttributionsAsReferrer    ReferralAttribution[]     @relation("ReferralReferrer")
  referralAttributionsAsReferred    ReferralAttribution[]     @relation("ReferralReferred")
  referralPayoutRequests            ReferralPayoutRequest[]   @relation("ReferralPayoutRequests")
  referralPayoutsMarkedBy           ReferralPayoutRequest[]   @relation("ReferralPayoutsMarkedBy")
  photographerSalesSettings        PhotographerSalesSettings?
  userUpsellConfigs               UserUpsellConfig[]
  /// Si true, puede recibir emails de marketing (campañas)
  marketingOptIn                   Boolean                   @default(false)
  /// Cuando el usuario se da de baja del marketing
  unsubscribedAt                   DateTime?
  /// Token único para link de unsubscribe (generado si falta)
  unsubscribeToken                 String?                   @unique
  /// AAIP: cuándo optó por marketing
  marketingOptInAt                 DateTime?
  marketingOptInIp                 String?
  marketingOptInSource              String?
  /// AAIP: consentimiento para reconocimiento facial (User-level)
  faceConsent                      Boolean                   @default(false)
  faceConsentAt                    DateTime?
  faceConsentIp                    String?
  schools                          School[]                  @relation("SchoolOwner")
}

/// Estado de campaña de email marketing
enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELED
}

/// Estado de cada envío individual
enum EmailSendStatus {
  QUEUED
  SENT
  FAILED
  BOUNCED
  COMPLAINED
}

/// Campaña de email marketing (admin)
model EmailCampaign {
  id               Int                 @id @default(autoincrement())
  name             String              /// Nombre interno
  subject          String
  previewText      String?
  fromName         String
  fromEmail        String
  html             String              @db.Text
  status           EmailCampaignStatus @default(DRAFT)
  audienceJson     Json?               /// { roles, workspaceId, filters }
  scheduledAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  createdByUserId  Int?
  sends            EmailSend[]

  @@index([status])
  @@index([createdAt])
}

/// Registro de cada email enviado en una campaña
model EmailSend {
  id                Int            @id @default(autoincrement())
  campaignId        Int
  toEmail           String
  toUserId          Int?
  status            EmailSendStatus @default(QUEUED)
  providerMessageId String?
  error             String?        @db.Text
  sentAt            DateTime?
  attempts          Int           @default(0)
  createdAt         DateTime       @default(now())
  campaign          EmailCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
}

/// * Capabilities para upsell engine (qué puede ofrecer el fotógrafo)
enum UpsellCapability {
  DIGITAL_SALES
  PRINT_SALES
  RETOUCH_PRO
  EXPRESS_DELIVERY
  STORAGE_EXTEND
}

/// * Configuración de ventas del fotógrafo (workspace): qué ofrece y precios/fulfillment
model PhotographerSalesSettings {
  id                      Int       @id @default(autoincrement())
  userId                  Int       @unique
  capabilities            String[]  @default([])
  digitalEnabled          Boolean   @default(true)
  printsEnabled           Boolean   @default(false)
  retouchEnabled          Boolean   @default(false)
  expressEnabled          Boolean   @default(false)
  storageExtendEnabled    Boolean   @default(false)
  printsPriceListJson     Json?
  printsFulfillmentJson   Json?
  retouchPricingJson      Json?
  expressPricingJson      Json?
  storageExtendPricingJson Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PhotographerProduct {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String
  size        String?
  acabado     String?
  retailPrice Int      @default(0)
  currency    String   @default("ARS")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([createdAt])
}

/// * Tipo de evento para álbumes colaborativos y eventos
enum EventType {
  PUBLIC_SESSION
  PRIVATE_SESSION
  SPORTS
  PUBLIC_PHOTOGRAPHY
  THEMATIC_SESSIONS
  COMMERCIAL_SESSIONS
  SCHOOL
  RELIGIOUS
  FESTIVAL
  CONFERENCE
  CONCERT
  CORPORATE
  OTHER
  // Valores legacy (eventos ya creados)
  WEDDING
  BIRTHDAY
  GRADUATION
}

/// * Visibilidad del evento
enum EventVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

/// * Política de unión al evento
enum EventJoinPolicy {
  OPEN
  REQUEST
  INVITE_ONLY
}

/// * Estado del miembro del evento
enum EventMemberStatus {
  PENDING
  ACTIVE
  REJECTED
}

/// * Tipo de entrega para fulfillment
enum DeliveryType {
  PICKUP
  SHIPPING
}

model Album {
  id                       Int                 @id @default(autoincrement())
  userId                   Int
  title                    String
  location                 String?
  eventDate                DateTime?
  publicSlug               String              @unique
  createdAt                DateTime            @default(now())
  /// Creador del álbum base (null = userId es el creador, backward compat)
  creatorId                Int?
  /// Evento asociado (álbum colaborativo vinculado a evento)
  eventId                  Int?
  /// Tipo de evento
  type                     EventType?
  /// Geohash para búsqueda por proximidad
  geohash                  String?
  latitude                 Float?
  longitude                Float?
  /// Ventana temporal del evento
  startsAt                 DateTime?
  endsAt                   DateTime?
  /// Ciudad (string, para matching)
  city                     String?
  /// Tipo de entrega por defecto
  deliveryType             DeliveryType?
  albumProfitMarginPercent Float?
  printPricingSource       PrintPricingSource @default(PHOTOGRAPHER)
  coverPhotoId             Int?
  digitalPhotoPriceCents   Int?
  pickupBy                 PickupBy?
  selectedLabId            Int?
  enableDigitalPhotos      Boolean             @default(true)
  enablePrintedPhotos      Boolean             @default(true)
  includeDigitalWithPrint  Boolean             @default(false)
  digitalWithPrintDiscountPercent Float?       @default(0)
  isHidden                 Boolean             @default(false)
  showComingSoonMessage    Boolean             @default(false)
  firstPhotoDate           DateTime?
  digitalDiscount10Plus    Float?
  digitalDiscount20Plus    Float?
  digitalDiscount5Plus     Float?
  termsAcceptedAt          DateTime?
  termsVersion             String?
  isPublic                 Boolean             @default(true)
  allowClientLabSelection  Boolean             @default(false)
  expirationExtensionDays  Int                 @default(0)
  expiresAt                DateTime            @default(now())
  reactivatedAt            DateTime?
  reactivationCount        Int                 @default(0)
  coverCropX               Float?
  coverCropY               Float?
  coverCropZoom            Float?
  coverCropAspect          Float?
  coverThumbnailKey        String?
  /// Máximo de fotos permitidas para descarga (por álbum, fijado por organizador)
  maxDownloadAllowed      Int?
  /// Fotos ocultas hasta verificación por selfie
  hiddenPhotosEnabled     Boolean             @default(false)
  /// Días de retención de selfie en R2 (null = no guardar)
  hiddenSelfieRetentionDays Int?
  deletedAt                DateTime?           // Soft delete: álbum "eliminado" pero se conservan pedidos y contactos
  /// Pre-compra PRO: cierre de pre-compra (ej. 1 día antes de la sesión); null = no pre-compra
  preCompraCloseAt         DateTime?
  /// Pre-compra PRO: si true, el cliente debe aprobar el diseño (1 ronda de cambios)
  requireClientApproval    Boolean             @default(false)
  /// Escuela vinculada (álbum escolar Etapa 1)
  schoolId                 Int?
  coverPhoto               Photo?              @relation("AlbumCoverPhoto", fields: [coverPhotoId], references: [id])
  selectedLab              Lab?                @relation("AlbumSelectedLab", fields: [selectedLabId], references: [id])
  user                     User                @relation(fields: [userId], references: [id])
  creator                  User?               @relation("AlbumCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  event                    Event?              @relation(fields: [eventId], references: [id], onDelete: SetNull)
  collaborators            AlbumCollaborator[]
  slugAliases              AlbumSlugAlias[]
  accesses                 AlbumAccess[]
  extensions               AlbumExtension[]
  interests                AlbumInterest[]
  invitations              AlbumInvitation[]
  notifications            AlbumNotification[]
  orders                   Order[]
  photos                   Photo[]
  removalRequests          RemovalRequest[]
  hiddenAlbumAttempts      HiddenAlbumAttempt[]
  hiddenAlbumGrants        HiddenAlbumGrant[]
  salesSettings            AlbumSalesSettings?
  preCompraProducts        AlbumProduct[]
  preCompraOrders          PreCompraOrder[]
  subjects                 Subject[]
  templates                Template[]       /// Plantillas del álbum (biblioteca) o asignadas a productos
  school                   School?         @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([creatorId])
  @@index([eventId])
  @@index([schoolId])
  @@index([geohash])
  @@index([coverPhotoId])
  @@index([selectedLabId])
  @@index([isHidden])
  @@index([deletedAt])
}

/// * Configuración de ventas por álbum: heredar o override capabilities
model AlbumSalesSettings {
  id                   Int      @id @default(autoincrement())
  albumId              Int      @unique
  inheritFromPhotographer Boolean @default(true)
  allowedCapabilities   String[] @default([])
  disabledCapabilities  String[] @default([])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  album                 Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

/// * Estado de estrategia de upsell (global, admin)
enum UpsellStrategyStatus {
  DRAFT
  QA
  BETA
  APPROVED
}

/// * Estrategias de upsell (definidas por plataforma)
model UpsellStrategy {
  id                  Int                 @id @default(autoincrement())
  slug                String              @unique
  name                String
  description         String?
  status              UpsellStrategyStatus @default(DRAFT)
  enabledGlobally     Boolean             @default(false)
  requiresCapabilities String[]           @default([])
  requiresConfigKeys  String[]            @default([])
  rulesJson           Json?
  rolloutPercent      Int                 @default(100)
  rolloutAllowlist     String[]  @default([])
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  userConfigs         UserUpsellConfig[]
}

/// * Por fotógrafo: qué estrategias tiene habilitadas
model UserUpsellConfig {
  id           Int            @id @default(autoincrement())
  userId       Int
  strategyId   Int
  enabled      Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy     UpsellStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@unique([userId, strategyId])
  @@index([userId])
  @@index([strategyId])
}

/// * Colaborador en álbum colaborativo
model AlbumCollaborator {
  id         Int      @id @default(autoincrement())
  albumId    Int
  userId     Int
  role       AlbumCollaboratorRole @default(COLLABORATOR)
  createdAt  DateTime @default(now())
  album      Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([albumId, userId])
  @@index([albumId])
  @@index([userId])
}

enum AlbumCollaboratorRole {
  COLLABORATOR
}

/// * Alias de slug para redirigir al álbum base
model AlbumSlugAlias {
  id             Int      @id @default(autoincrement())
  aliasSlug      String   @unique
  targetAlbumId  Int
  createdAt      DateTime @default(now())
  targetAlbum    Album    @relation(fields: [targetAlbumId], references: [id], onDelete: Cascade)

  @@index([aliasSlug])
  @@index([targetAlbumId])
}

/// * Evento georeferenciado creado por organizador
model Event {
  id                Int               @id @default(autoincrement())
  title             String
  description       String?
  type              EventType
  startsAt          DateTime
  endsAt            DateTime?
  latitude          Float
  longitude         Float
  locationName      String?
  city              String
  geohash           String?
  visibility        EventVisibility   @default(PUBLIC)
  joinPolicy        EventJoinPolicy   @default(OPEN)
  maxPhotographers  Int?
  /// Cantidad aproximada de asistentes (para que el fotógrafo sepa si es multitudinario)
  expectedAttendees Int?
  creatorId         Int
  promoCommitment   Boolean           @default(false)
  promoText         String?
  /// Indicaciones para que el fotógrafo se acredite (visible en la vista del evento)
  accreditationNotes String?
  /// Slug único para link público de invitación (/e/[shareSlug])
  shareSlug         String?           @unique
  /// Key en R2 de la imagen de portada del evento
  coverImageKey     String?
  mergedIntoId      Int?
  /// Si está definido, el evento fue dado de baja (no se muestra en listados; 7+ días pasados y 0 fotógrafos inscritos)
  archivedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  creator           User              @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  mergedInto        Event?            @relation("EventMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedEvents      Event[]           @relation("EventMerge")
  members           EventMember[]
  invitedPhotographers EventInvitation[]
  albums            Album[]
  similaritiesA     EventSimilarity[] @relation("EventSimilarityA")
  similaritiesB     EventSimilarity[] @relation("EventSimilarityB")
  downloadAllowances OrganizerDownloadAllowance[]

  @@index([creatorId])
  @@index([city])
  @@index([geohash])
  @@index([startsAt])
  @@index([mergedIntoId])
  @@index([shareSlug])
  @@index([archivedAt])
}

/// * Miembro del evento (organizador o fotógrafo)
model EventMember {
  id        Int              @id @default(autoincrement())
  eventId   Int
  userId    Int
  role      EventMemberRole
  status    EventMemberStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

/// * Invitación de fotógrafo a evento privado (solo ellos pueden ver/inscribirse)
model EventInvitation {
  id        Int      @id @default(autoincrement())
  eventId   Int
  userId    Int
  invitedAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

enum EventMemberRole {
  ORGANIZER
  PHOTOGRAPHER
}

/// * Similitud entre eventos (alertas admin)
model EventSimilarity {
  id          Int                  @id @default(autoincrement())
  eventAId    Int
  eventBId    Int
  score       Float
  status      EventSimilarityStatus @default(SUGGESTED)
  createdAt   DateTime             @default(now())
  eventA      Event                @relation("EventSimilarityA", fields: [eventAId], references: [id], onDelete: Cascade)
  eventB      Event                @relation("EventSimilarityB", fields: [eventBId], references: [id], onDelete: Cascade)

  @@unique([eventAId, eventBId])
  @@index([status])
}

enum EventSimilarityStatus {
  SUGGESTED
  MERGED_MANUALLY
  REJECTED
}

/// * Límite de descargas para organizador (10 por fotógrafo por evento)
model OrganizerDownloadAllowance {
  id              Int      @id @default(autoincrement())
  eventId         Int
  photographerId  Int
  usedDownloads   Int      @default(0)
  maxDownloads    Int      @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photographer    User     @relation(fields: [photographerId], references: [id], onDelete: Cascade)

  @@unique([eventId, photographerId])
  @@index([eventId])
  @@index([photographerId])
}

/// * Notificación in-app para dashboard
model DashboardNotification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
}

model PhotobookDocument {
  id        String   @id @default(cuid())
  title     String?
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([updatedAt])
}

model AlbumInvitation {
  id               String    @id @default(cuid())
  albumId          Int
  invitedEmail     String
  invitedByUserId  Int
  tokenHash        String    @unique
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  acceptedAt       DateTime?
  acceptedByUserId Int?
  acceptedBy       User?     @relation("AlbumInvitationAcceptedBy", fields: [acceptedByUserId], references: [id])
  album            Album     @relation(fields: [albumId], references: [id])
  invitedBy        User      @relation("AlbumInvitationInvitedBy", fields: [invitedByUserId], references: [id])
  status           AlbumInvitationStatus @default(PENDING)

  @@index([albumId])
  @@index([invitedEmail])
}

enum AlbumInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum PrintPricingSource {
  PHOTOGRAPHER
  LAB_PREFERRED
}

enum PhotoAnalysisStatus {
  PENDING
  PROCESSING
  DONE
  ERROR
}

model AlbumAccess {
  id        Int             @id @default(autoincrement())
  albumId   Int
  userId    Int
  role      AlbumAccessRole @default(VIEWER)
  createdAt DateTime        @default(now())
  album     Album           @relation(fields: [albumId], references: [id])
  user      User            @relation(fields: [userId], references: [id])

  @@unique([albumId, userId])
  @@index([albumId])
  @@index([userId])
}

/// * Escuela (módulo fotografía escolar Etapa 1)
model School {
  id           Int      @id @default(autoincrement())
  ownerId      Int
  name         String
  slug         String?  @unique
  contactEmail String?
  contactPhone String?
  notes        String?
  /// Dirección completa (ej. desde Google Maps / Nominatim)
  address      String?
  city         String?
  province     String?
  country      String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  owner        User     @relation("SchoolOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  courses      SchoolCourse[]
  albums       Album[]

  @@index([ownerId])
}

/// * Curso/división de una escuela
model SchoolCourse {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  name      String   /// ej. "1ro", "Sala 5", "2do"
  division  String?  /// ej. "A", "B" (null = sin división)
  sortOrder Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school            School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjects          Subject[]
  preCompraOrders   PreCompraOrder[]

  @@index([schoolId])
}

model Photo {
  id              Int              @id @default(autoincrement())
  albumId         Int
  previewUrl      String
  originalKey     String
  createdAt       DateTime         @default(now())
  userId          Int?
  /// Si true, esta foto se puede vender como digital (por defecto sí)
  sellDigital     Boolean          @default(true)
  /// Si true, esta foto se puede vender como impresa (por defecto sí)
  sellPrint       Boolean          @default(true)
  isRemoved       Boolean          @default(false)
  removedAt       DateTime?
  removedReason   String?
  analysisStatus  PhotoAnalysisStatus @default(PENDING)
  analysisError   String?
  analyzedAt      DateTime?
  albumsAsCover   Album[]          @relation("AlbumCoverPhoto")
  items           OrderItem[]
  album           Album            @relation(fields: [albumId], references: [id])
  uploadedBy      User?            @relation("PhotoUploader", fields: [userId], references: [id])
  removalRequests RemovalRequest[]
  analysisJob     PhotoAnalysisJob?
  ocrTokens       OcrToken[]
  faceDetections  FaceDetection[]
  faceMatchEvents FaceMatchEvent[]
  photoFaces      PhotoFace[]
  faceMatches     FaceMatch[]
  photoClaims     PhotoClaim[]
  selectionPhotos SelectionPhoto[]

  @@index([albumId])
  @@index([userId])
  @@index([isRemoved])
}

model PhotoAnalysisJob {
  id        Int                 @id @default(autoincrement())
  photoId   Int                 @unique
  status    PhotoAnalysisStatus @default(PENDING)
  attempts  Int                 @default(0)
  lockedAt  DateTime?
  runAfter  DateTime?
  lastError String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  photo     Photo               @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([runAfter])
  @@index([lockedAt])
}

model OcrToken {
  id         Int      @id @default(autoincrement())
  photoId    Int
  textRaw    String
  textNorm   String
  confidence Float?
  createdAt  DateTime @default(now())
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([photoId])
  @@index([textNorm])
}

model FaceDetection {
  id                  Int              @id @default(autoincrement())
  photoId             Int
  rekognitionFaceId   String           @unique
  confidence          Float?
  bbox                Json
  createdAt           DateTime         @default(now())
  photo               Photo            @relation(fields: [photoId], references: [id], onDelete: Cascade)
  faceMatchEvents     FaceMatchEvent[]

  @@index([photoId])
}

model Order {
  id                      Int         @id @default(autoincrement())
  albumId                 Int
  buyerEmail              String
  buyerUserId             Int?
  buyerPhone              String?
  claimedAt               DateTime?
  status                  OrderStatus @default(PENDING)
  /// Total en ARS enteros (no centavos). Se conserva el sufijo "Cents" por compatibilidad histórica.
  totalCents              Int         @default(0)
  createdAt               DateTime    @default(now())
  /// Recargo por extensión en ARS enteros (no centavos).
  extensionSurchargeCents Int         @default(0)
  mpPreferenceId          String?
  mpInitPoint             String?
  mpPaymentId             String?
  platformCommissionCents Int?        @default(0)
  pricingSnapshot         Json?
  /// Descuento aplicado del saldo de referidos del dueño del álbum a este pedido (centavos)
  referralFeeDiscountCents Int?
  digitalDeliveredAt      DateTime?
  /// Primera vez que el cliente abrió el link de descarga o descargó (para mostrar en panel fotógrafo/admin)
  downloadLinkViewedAt    DateTime?
  album                   Album       @relation(fields: [albumId], references: [id])
  items                   OrderItem[]
  fulfillmentGroups       OrderFulfillmentGroup[]
  buyerUser               User?       @relation("OrderBuyerUser", fields: [buyerUserId], references: [id], onDelete: SetNull)
  abandonedReminders      AbandonedOrderReminder[]
  whatsappDeliveryLogs    WhatsAppDeliveryLog[]

  @@index([albumId])
  @@index([buyerUserId])
  @@index([buyerEmail])
}

/// * Recordatorio de pedido abandonado (WhatsApp, email, etc.)
model AbandonedOrderReminder {
  id           String   @id @default(cuid())
  orderId      Int
  sentAt       DateTime @default(now())
  channel      String   /// "WHATSAPP" | "EMAIL"
  templateUsed String
  status       String   /// "SENT" | "FAILED"
  errorMessage String?
  createdAt    DateTime @default(now())

  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, channel])
  @@index([orderId])
  @@index([createdAt])
}

/// * Grupo de fulfillment por fotógrafo (multi-entrega)
model OrderFulfillmentGroup {
  id             Int           @id @default(autoincrement())
  orderId        Int
  photographerId Int
  deliveryType   DeliveryType  @default(PICKUP)
  pickupAddress  Json?         /// { addressLine1, city, province, postalCode, country }
  createdAt      DateTime      @default(now())
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items          OrderItem[]

  @@index([orderId])
  @@index([photographerId])
}

model OrderItem {
  id                   Int                    @id @default(autoincrement())
  orderId              Int
  photoId              Int
  fulfillmentGroupId   Int?                   /// null = legacy single group
  /// Precio unitario en ARS enteros (no centavos).
  priceCents           Int                    @default(0)
  finish               String?                // Acabado libre: BRILLO, MATE, CUERO, ARENA, LIJA, etc. (lo que ofrezca el lab/fotógrafo)
  material             ProductMaterial?
  productType          OrderItemType          @default(DIGITAL)
  quantity             Int                    @default(1)
  size                 String?
  /// Subtotal en ARS enteros (no centavos).
  subtotalCents        Int                    @default(0)
  order                Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fulfillmentGroup     OrderFulfillmentGroup? @relation(fields: [fulfillmentGroupId], references: [id], onDelete: SetNull)
  photo                Photo                  @relation(fields: [photoId], references: [id])

  @@index([orderId])
  @@index([photoId])
  @@index([fulfillmentGroupId])
  @@index([productType])
}

// ========== PRE-COMPRA PRO (escuelas) ==========

/// * Producto de pre-compra por álbum (catálogo sin fotos)
model AlbumProduct {
  id                 Int        @id @default(autoincrement())
  albumId            Int
  name               String
  description        String?
  /// Precio en ARS enteros
  price              Int        @default(0)
  mockupUrl          String?
  minFotos           Int        @default(1)
  maxFotos           Int        @default(1)
  requiresDesign     Boolean    @default(false)
  suggestionText     String?
  defaultTemplateId  Int?       @unique
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  album              Album      @relation(fields: [albumId], references: [id], onDelete: Cascade)
  templates          Template[]
  defaultTemplate    Template?  @relation("AlbumProductDefaultTemplate", fields: [defaultTemplateId], references: [id], onDelete: SetNull)
  orderItems         PreCompraOrderItem[]

  @@index([albumId])
}

/// * Pedido de pre-compra (cliente compró catálogo; con/sin pago según flujo)
model PreCompraOrder {
  id                Int       @id @default(autoincrement())
  albumId           Int
  buyerEmail        String
  buyerUserId       Int?
  buyerName         String?
  buyerPhone        String?
  schoolCourseId    Int?
  studentFirstName  String?
  studentLastName  String?
  status            PreCompraOrderStatus @default(CREATED)
  totalCents        Int       @default(0)
  mpPreferenceId    String?
  mpInitPoint       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  album             Album     @relation(fields: [albumId], references: [id], onDelete: Cascade)
  schoolCourse      SchoolCourse? @relation(fields: [schoolCourseId], references: [id], onDelete: SetNull)
  items             PreCompraOrderItem[]
  subjects          Subject[]
  selfies           SubjectSelfie[]
  photoClaims       PhotoClaim[]

  @@index([albumId])
  @@index([buyerEmail])
  @@index([buyerUserId])
  @@index([schoolCourseId])
}

enum PreCompraOrderStatus {
  CREATED
  PAID_HELD
  CANCELED
}

/// * Ítem del pedido de pre-compra (por producto del catálogo)
model PreCompraOrderItem {
  id               Int                      @id @default(autoincrement())
  orderId          Int
  albumProductId   Int
  subjectId        Int?                     /// Niño asignado (opcional hasta selfie/selección)
  status           PreCompraOrderItemStatus @default(WAITING_SELFIE)
  approvalProof    ApprovalProof?           /// FACE_MATCH | SELECTION
  approvedAt       DateTime?
  priceCents       Int                      @default(0)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  order            PreCompraOrder           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  albumProduct     AlbumProduct             @relation(fields: [albumProductId], references: [id], onDelete: Cascade)
  subject          Subject?                 @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  selection        Selection?
  designProject    DesignProject?

  @@index([orderId])
  @@index([albumProductId])
  @@index([subjectId])
  @@index([status])
}

enum PreCompraOrderItemStatus {
  WAITING_SELFIE
  WAITING_UPLOAD
  APPROVED_BY_MATCH
  WAITING_SELECTION
  READY_TO_DESIGN
  DESIGN_SUBMITTED
  NEEDS_CHANGES
  APPROVED
  EXPORTED
}

enum ApprovalProof {
  FACE_MATCH
  SELECTION
}

/// * Niño/sujeto por familia (nombre ej. "Gime"); vinculado a orden y álbum
model Subject {
  id                Int       @id @default(autoincrement())
  albumId           Int
  label             String    /// ej. "Gime" o "Nombre Apellido" (backward compat)
  firstName         String?
  lastName          String?
  schoolCourseId    Int?
  createdByOrderId  Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  album             Album     @relation(fields: [albumId], references: [id], onDelete: Cascade)
  createdByOrder    PreCompraOrder? @relation(fields: [createdByOrderId], references: [id], onDelete: SetNull)
  schoolCourse      SchoolCourse? @relation(fields: [schoolCourseId], references: [id], onDelete: SetNull)
  selfies           SubjectSelfie[]
  faceMatches       FaceMatch[]
  photoClaims       PhotoClaim[]
  orderItems        PreCompraOrderItem[]
  selectionPhotos   SelectionPhoto[]  /// Fotos elegidas en selección (subjectId en SelectionPhoto)

  @@index([albumId])
  @@index([createdByOrderId])
  @@index([schoolCourseId])
}

/// * Selfie del niño para matching facial
model SubjectSelfie {
  id         Int       @id @default(autoincrement())
  subjectId  Int
  orderId    Int
  imageUrl   String    /// URL en R2 o CDN
  createdAt  DateTime  @default(now())
  subject    Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  order      PreCompraOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([subjectId])
  @@index([orderId])
}

/// * Cara detectada en una foto (para matching con selfies)
model PhotoFace {
  id              Int       @id @default(autoincrement())
  photoId         Int
  bbox            Json      /// { x, y, width, height } normalizado o px
  faceExternalId  String?   /// ID del proveedor de detección (ej. Rekognition)
  faceCount       Int       @default(1)   /// En foto grupal > 1
  createdAt       DateTime  @default(now())
  photo           Photo     @relation(fields: [photoId], references: [id], onDelete: Cascade)
  faceMatches     FaceMatch[]

  @@index([photoId])
}

/// * Match entre un subject (selfie) y una foto
model FaceMatch {
  id          Int       @id @default(autoincrement())
  subjectId   Int
  photoId     Int
  photoFaceId Int?
  confidence  Float?
  isManual    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  photo       Photo     @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoFace   PhotoFace? @relation(fields: [photoFaceId], references: [id], onDelete: SetNull)

  @@unique([subjectId, photoId])
  @@index([subjectId])
  @@index([photoId])
  @@index([photoFaceId])
}

/// * Reclamo "Esta foto es mi hijo" → aprobación manual del fotógrafo
model PhotoClaim {
  id         Int            @id @default(autoincrement())
  photoId    Int
  subjectId  Int
  orderId    Int
  status     PhotoClaimStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  photo      Photo          @relation(fields: [photoId], references: [id], onDelete: Cascade)
  subject    Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  order      PreCompraOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([photoId])
  @@index([subjectId])
  @@index([orderId])
  @@index([status])
}

enum PhotoClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

/// * Selección de fotos enviada por el cliente (para un ítem)
model Selection {
  id            Int       @id @default(autoincrement())
  orderItemId  Int       @unique
  createdAt    DateTime  @default(now())
  orderItem    PreCompraOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  photos       SelectionPhoto[]

  @@index([orderItemId])
}

model SelectionPhoto {
  id          Int      @id @default(autoincrement())
  selectionId Int
  photoId     Int
  position    Int?     @default(0)
  selection   Selection @relation(fields: [selectionId], references: [id], onDelete: Cascade)
  photo       Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  subject     Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  subjectId   Int?

  @@index([selectionId])
  @@index([photoId])
}

/// * Plantilla: puede ser de la biblioteca del álbum (albumProductId null) o asignada a un producto.
/// albumId null = plantilla pública del sistema (solo admin). Si albumId set = plantilla de ese álbum.
model Template {
  id                  Int       @id @default(autoincrement())
  albumId             Int?      /// null = plantilla pública del sistema (cualquier fotógrafo puede usarla); si set = de este álbum
  albumProductId      Int?      /// null = plantilla de la biblioteca del álbum; si está set = asignada a este producto
  name                String    /// ej. "Díptico 4 fotos - Modelo A"
  imageUrl            String
  greenColorHex       String    @default("#00ff00")
  tolerance           Int       @default(30)   /// 0-100
  widthCm             Float
  heightCm            Float
  safeAreaConfigJson  Json?     /// { insetPx or percent }
  textElementsJson    Json?     /// [{ id, x, y, text, fontSize, fontFamily, fill }] en px de la imagen, editables luego en el diseñador
  isSystemTemplate    Boolean   @default(false) /// true = plantilla del sistema, visible para todos por temática
  theme               String?   /// Temática para filtrar (ej. "Bodas", "Cumpleaños")
  pagesJson           Json?     /// Hojas adicionales: [{ imageUrl, widthCm, heightCm, slots, textElements }]; la primera hoja es imageUrl/slots actuales
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  album               Album?    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  albumProduct        AlbumProduct? @relation(fields: [albumProductId], references: [id], onDelete: Cascade)
  defaultForProduct   AlbumProduct? @relation("AlbumProductDefaultTemplate")
  slots               TemplateSlot[]
  designProjects      DesignProject[]

  @@index([albumId])
  @@index([albumProductId])
}

model TemplateSlot {
  id          Int      @id @default(autoincrement())
  templateId  Int
  index       Int      /// Orden izq→der, arriba→abajo
  bbox        Json     /// { x, y, width, height } en px o normalizado
  maskPngUrl  String?  /// Máscara alpha por hueco
  createdAt   DateTime @default(now())
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

/// * Proyecto de diseño (cliente diseña, fotógrafo aprueba)
model DesignProject {
  id                  Int                 @id @default(autoincrement())
  orderItemId         Int                 @unique
  templateId          Int
  status              DesignProjectStatus @default(DRAFT)
  currentRevisionId   Int?                @unique
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  orderItem           PreCompraOrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  template            Template            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  currentRevision     DesignRevision?     @relation("DesignProjectCurrentRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull)
  revisions           DesignRevision[]    @relation("DesignProjectRevisions")

  @@index([orderItemId])
  @@index([templateId])
  @@index([status])
}


enum DesignProjectStatus {
  DRAFT
  SUBMITTED
  NEEDS_CHANGES
  APPROVED
}

model DesignRevision {
  id              Int       @id @default(autoincrement())
  designProjectId Int
  createdBy       DesignRevisionCreatedBy @default(CLIENT)
  dataJson        Json?     /// Transforms por slot
  exportedJpgUrl  String?
  createdAt       DateTime  @default(now())
  designProject   DesignProject @relation("DesignProjectRevisions", fields: [designProjectId], references: [id], onDelete: Cascade)
  projectCurrent  DesignProject? @relation("DesignProjectCurrentRevision")

  @@index([designProjectId])
}

enum DesignRevisionCreatedBy {
  CLIENT
  PHOTOGRAPHER
}

/// *
/// * Pedido de impresión (cliente sube sus fotos)
model PrintOrder {
  id                     Int                       @id @default(autoincrement())
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  labId                  Int?                      // null = pedido va al fotógrafo (precios de su lista de productos)
  photographerId         Int?
  ownerType             PrintOrderOwnerType?     // trazabilidad: dueño de la landing (FASE 1)
  ownerId               Int?
  customerName           String?
  customerEmail          String?
  customerPhone          String?
  pickupBy               PickupBy                  @default(CLIENT)
  status                 PrintOrderStatus          @default(CREATED)
  statusUpdatedAt        DateTime                  @default(now())
  currency               String                    @default("ARS")
  /// Total en ARS enteros (no centavos).
  total                  Int                       @default(0)
  paymentProvider        String?
  paymentStatus          PrintOrderPaymentStatus   @default(PENDING)
  mpPreferenceId         String?
  mpInitPoint            String?
  mpPaymentId            String?
  clientId               Int?
  internalNotes          String?
  labCommission          Int?
  orderType              PrintOrderType            @default(PRINT)
  photographerCommission Int?
  platformCommission     Int?
  tags                       String[]                  @default([])
  pricingSnapshot            Json?
  /// Descuento aplicado del saldo de referidos del fotógrafo a este pedido (centavos)
  referralFeeDiscountCents   Int?
  adminLogs                  AdminLog[]                @relation("AdminLogPrintOrder")
  paymentSplit           PaymentSplit?             @relation("PaymentSplit")
  client                 User?                     @relation("ClientOrders", fields: [clientId], references: [id])
  lab                    Lab?                      @relation(fields: [labId], references: [id])
  photographer           User?                     @relation("PhotographerOrders", fields: [photographerId], references: [id])
  items                  PrintOrderItem[]
  statusHistory          PrintOrderStatusHistory[] @relation("PrintOrderStatusHistory")
  supportTickets         SupportTicket[]

  @@index([labId])
  @@index([photographerId])
  @@index([clientId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderType])
  @@index([createdAt])
}

/// *
/// * Item de impresión: UNA foto subida + configuración (tamaño, acabado, cantidad)
model PrintOrderItem {
  id           Int        @id @default(autoincrement())
  createdAt    DateTime   @default(now())
  orderId      Int
  fileKey      String
  originalName String?
  size         String
  acabado      String     @default("BRILLO")
  quantity     Int        @default(1)
  /// Precio unitario en ARS enteros (no centavos).
  unitPrice    Int        @default(0)
  /// Subtotal en ARS enteros (no centavos).
  subtotal     Int        @default(0)
  /// Metadata adicional para reimpresión (carnet/polaroids).
  meta         Json?
  /// Fecha de expiración para borrar archivos finales (R2).
  printExpiresAt DateTime?
  order        PrintOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Lab {
  id                            Int                 @id @default(autoincrement())
  name                          String
  email                         String?             @unique
  phone                         String?
  address                       String?
  city                          String?
  province                      String?
  country                       String?             @default("Argentina")
  /// Ubicación georeferenciada del laboratorio (para perfil y proximidad)
  latitude                      Float?
  longitude                     Float?
  isActive                      Boolean             @default(true)
  createdAt                     DateTime            @default(now())
  isPublicPageEnabled           Boolean             @default(false)
  showCarnetPrints              Boolean             @default(false)
  showPolaroidPrints            Boolean             @default(false)
  logoUrl                       String?
  primaryColor                  String?
  publicPageHandler             String?             @unique
  secondaryColor                String?
  tertiaryColor                 String?
  fontColor                     String?
  userId                        Int?                @unique
  approvalStatus                LabApprovalStatus   @default(PENDING)
  mpAccessToken                 String?
  mpConnectedAt                 DateTime?
  mpRefreshToken                String?
  mpUserId                      String?
  commissionOverrideBps         Int?
  internalNotes                 String?
  isSuspended                   Boolean             @default(false)
  labType                       LabType             @default(TYPE_B)
  suspendedAt                   DateTime?
  suspendedReason               String?
  tags                          String[]            @default([])
  defaultSlaDays                Int?
  fulfillmentMode               FulfillmentMode     @default(PICKUP_ONLY)
  radiusKm                      Int?
  rejectedAt                    DateTime?
  rejectedReason                String?
  shippingEnabled               Boolean             @default(false)
  soyFotografo                  Boolean             @default(false)
  usePriceForPhotographerOrders PriceMode           @default(AUTO)
  albumsWithSelectedLab         Album[]             @relation("AlbumSelectedLab")
  contactMessages               ContactMessage[]    @relation("ContactMessageLab")
  user                          User?               @relation("LabUser", fields: [userId], references: [id])
  basePrices                    LabBasePrice[]
  products                      LabProduct[]
  productVariants               LabProductVariant[]
  discounts                     LabSizeDiscount[]
  orders                        PrintOrder[]
  preferredByUsers              User[]              @relation("PhotographerPreferredLab")

  @@index([approvalStatus])
  @@index([userId])
  @@index([labType])
  @@index([soyFotografo])
  @@index([province, city])
}

/// *
/// * Laboratorios recomendados por fotógrafos (formulario público + panel admin)
model LabRecommendation {
  id               Int       @id @default(autoincrement())
  photographerName String
  labName          String
  labEmail         String
  labWhatsapp      String?
  createdAt        DateTime  @default(now())
  emailSentAt      DateTime?

  @@index([createdAt])
}

model LabBasePrice {
  id        Int      @id @default(autoincrement())
  labId     Int
  size      String
  unitPrice Int
  currency  String   @default("ARS")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lab       Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@unique([labId, size])
  @@index([labId])
}

model LabSizeDiscount {
  id              Int      @id @default(autoincrement())
  labId           Int
  size            String
  minQty          Int
  discountPercent Float
  priceType       String   @default("PROFESSIONAL") /// PROFESSIONAL = precios fotógrafo, PUBLIC = precios público
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lab             Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@unique([labId, size, minQty, priceType])
  @@index([labId])
}

/// *
/// * Productos del laboratorio con precios mayorista (fotógrafo) y retail (cliente final)
model LabProduct {
  id                Int      @id @default(autoincrement())
  labId             Int
  name              String
  size              String?
  photographerPrice Int
  retailPrice       Int
  currency          String   @default("ARS")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  acabado           String?
  lab               Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@index([labId])
  @@index([isActive])
}

/// *
/// * Variantes de productos del laboratorio (estructura completa para importación XLSX)
model LabProductVariant {
  id                Int              @id @default(autoincrement())
  labId             Int
  productName       String
  category          String?
  description       String?
  size              String?
  finish            PrintFinish?
  material          ProductMaterial?
  slaDays           Int              @default(5)
  priceRetailArs    Int?
  priceWholesaleArs Int?
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  lab               Lab              @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@unique([labId, productName, size, finish, material])
  @@index([labId])
  @@index([isActive])
  @@index([category])
}

/// *
/// * Configuración del sistema (precio mínimo de fotos digitales, tax de app, etc.)
model SystemSettings {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

/// *
/// * Configuración global de la aplicación (solo una fila con id=1)
model AppConfig {
  id                              Int      @id @unique @default(1)
  minDigitalPhotoPrice            Int      @default(5000)
  platformCommissionPercent       Int      @default(10)
  updatedAt                       DateTime @updatedAt
  adminCommissionRetailPercent    Float?   @default(10)
  adminCommissionWholesalePercent Float?   @default(8)
  commissionDigital_Bps           Int      @default(1000)
  commissionPro_Bps               Int?
  commissionPublicTypeA_Bps       Int      @default(750)
  commissionPublicTypeB_Bps       Int      @default(1000)
  downloadLinkDays                Int      @default(30)
  maintenanceMode                 Boolean  @default(false)
  photoDeletionDays               Int      @default(45)
  stuckOrderDays                  Int      @default(7)
  /// Entrega post-compra por WhatsApp
  whatsappEnabled                 Boolean  @default(false)
  whatsappMaxPhotosToSend         Int      @default(10)
  whatsappSendInitialMessage      Boolean  @default(true)
